{
    "name": "arnaudmoncondhuy/synapse-bundle",
    "description": "Bundle Synapse complet — orchestration IA pour Symfony avec admin et chat intégrés.",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Arnaud Moncondhuy",
            "email": "arnaudmoncondhuy@gmail.com"
        }
    ],
    "license": "PolyForm-Noncommercial-1.0.0",
    "require": {
        "arnaudmoncondhuy/synapse-core": "dev-main",
        "arnaudmoncondhuy/synapse-admin": "dev-main",
        "arnaudmoncondhuy/synapse-chat": "dev-main",
        "symfony/translation": "^7.0 || ^8.0"
    },
    "require-dev": {
        "arnaudmoncondhuy/synapse-admin": "@dev",
        "arnaudmoncondhuy/synapse-chat": "@dev",
        "arnaudmoncondhuy/synapse-core": "@dev",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "roave/security-advisories": "dev-latest",
        "symfony/process": "^8.0",
        "symfony/test-pack": "^1.2",
        "symplify/monorepo-builder": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ArnaudMoncondhuy\\SynapseCore\\": "packages/core/src/",
            "ArnaudMoncondhuy\\SynapseAdmin\\": "packages/admin/src/",
            "ArnaudMoncondhuy\\SynapseChat\\": "packages/chat/src/",
            "ArnaudMoncondhuy\\SynapseMcp\\": "packages/mcp/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArnaudMoncondhuy\\SynapseCore\\Tests\\": "packages/core/tests/",
            "ArnaudMoncondhuy\\SynapseAdmin\\Tests\\": "packages/admin/tests/",
            "ArnaudMoncondhuy\\SynapseMcp\\Tests\\": "packages/mcp/tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/admin",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/chat",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/mcp",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "allow-plugins": {
            "symplify/monorepo-builder": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "scripts": {
        "validate-monorepo": "vendor/bin/monorepo-builder validate",
        "merge": "vendor/bin/monorepo-builder merge",
        "release": "vendor/bin/monorepo-builder release",
        "phpstan": "vendor/bin/phpstan analyse -c qa/phpstan.neon",
        "cs-check": "vendor/bin/php-cs-fixer fix --config=qa/.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "vendor/bin/php-cs-fixer fix --config=qa/.php-cs-fixer.dist.php",
        "test": "vendor/bin/phpunit -c qa/phpunit.xml.dist",
        "check": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
