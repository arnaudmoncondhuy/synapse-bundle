{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}Assistant Preset | Intelligence | Administration Synapse{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_configuration_llm') }}" class="synapse-admin-topbar__breadcrumb">Intelligence</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-topbar__breadcrumb">Model Presets</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">Assistant</span>
{% endblock %}

{% block admin_content %}

	{# ── En-tête ──────────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="wand-2"></i>
				</span>
				Assistant de configuration
			</h1>
			<p class="synapse-admin-page-subtitle">
				Dites-nous ce que vous voulez faire, on s'occupe du reste.
			</p>
		</div>
	</div>

	{# ── Écran de chargement (caché par défaut) ───────────────────────────── #}
	<div id="wizard-loading" style="display: none;">
		<div style="display: flex; align-items: center; justify-content: center; min-height: 50vh;">
			<div style="text-align: center;">
				<div class="synapse-admin-mb-lg">
					<div style="width: 48px; height: 48px; border: 4px solid var(--sa-border); border-top-color: var(--sa-primary); border-radius: 50%; animation: synapse-spin 0.8s linear infinite; margin: 0 auto;"></div>
				</div>
				<h2 class="synapse-admin-text-lg synapse-admin-mb-sm" style="font-weight: 600;" id="loading-title">Analyse en cours...</h2>
				<p class="synapse-admin-text-sm synapse-admin-text-muted" id="loading-subtitle">L'assistant étudie vos besoins et sélectionne le meilleur modèle.</p>
			</div>
		</div>
	</div>
	<style>@keyframes synapse-spin { to { transform: rotate(360deg); } }</style>

	{% if step is defined and step == 'created' %}
		{# ══════════════════════════════════════════════════════════════════════════ #}
		{# CROSS-LINK : Preset créé → proposer de créer un agent                    #}
		{# ══════════════════════════════════════════════════════════════════════════ #}

		<div style="max-width: 800px;">
			<div class="synapse-admin-card synapse-admin-card--success synapse-admin-mb-lg">
				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
						<i data-lucide="check-circle-2"></i>
					</div>
					<span class="synapse-admin-card__title">Preset « {{ created_preset_name }} » créé avec succès</span>
				</div>
			</div>

			<div class="synapse-admin-card">
				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
						<i data-lucide="target"></i>
					</div>
					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
						<span class="synapse-admin-card__title">Voulez-vous créer un agent avec ce preset ?</span>
						<span class="synapse-admin-text-sm synapse-admin-text-muted">
							Un agent combine un preset LLM avec un prompt système dédié pour une tâche spécifique.
						</span>
					</div>
				</div>
				<div class="synapse-admin-card__footer">
					<div class="synapse-admin-flex synapse-admin-gap-md">
						<a href="{{ path('synapse_admin_agents_wizard', {preset_id: created_preset_id}) }}" class="synapse-admin-btn synapse-admin-btn--primary">
							<i data-lucide="wand-2"></i> Oui, créer un agent
						</a>
						<a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-btn synapse-admin-btn--ghost">
							Non merci
						</a>
					</div>
				</div>
			</div>
		</div>

	{% elseif step is defined and step == 'result' and recommendation is defined %}
		{# ══════════════════════════════════════════════════════════════════════════ #}
		{# RÉSULTAT                                                                  #}
		{# ══════════════════════════════════════════════════════════════════════════ #}

		<div class="synapse-admin-card synapse-admin-card--success" style="max-width: 800px;">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="check-circle-2"></i>
				</div>
				<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
					<span class="synapse-admin-card__title">Recommandation</span>
					<span class="synapse-admin-text-sm synapse-admin-text-muted">
						{% if recommendation.llm_assisted %}
							<span class="synapse-admin-badge synapse-admin-badge--primary"><i data-lucide="sparkles" style="width: 12px; height: 12px;"></i> IA</span> Recommandation assistée par IA
						{% else %}
							<span class="synapse-admin-badge synapse-admin-badge--info">Auto</span> Recommandation automatique
						{% endif %}
					</span>
				</div>
			</div>

			<div class="synapse-admin-card__body">
				<table class="synapse-admin-table synapse-admin-table--compact" style="width: 100%;">
					<tbody>
						<tr><td class="synapse-admin-text-muted" style="width: 180px;">Nom</td><td><strong>{{ recommendation.suggested_name }}</strong></td></tr>
						<tr><td class="synapse-admin-text-muted">Provider</td><td>{{ recommendation.provider }}</td></tr>
						<tr><td class="synapse-admin-text-muted">Modèle</td><td><code>{{ recommendation.model }}</code></td></tr>
						<tr><td class="synapse-admin-text-muted">Gamme</td><td>
							{% set rangeBadge = {flagship: 'primary', balanced: 'info', fast: 'success', specialized: 'warning'} %}
							<span class="synapse-admin-badge synapse-admin-badge--{{ rangeBadge[recommendation.range] ?? 'default' }}">{{ recommendation.range }}</span>
						</td></tr>
						<tr><td class="synapse-admin-text-muted">Température</td><td>{{ recommendation.temperature }}</td></tr>
						<tr><td class="synapse-admin-text-muted">Top P</td><td>{{ recommendation.top_p }}</td></tr>
						<tr><td class="synapse-admin-text-muted">Top K</td><td>{{ recommendation.top_k ?? '—' }}</td></tr>
						<tr><td class="synapse-admin-text-muted">Streaming</td><td>{{ recommendation.streaming_enabled ? 'Oui' : 'Non' }}</td></tr>
						{% if recommendation.provider_options and recommendation.provider_options.thinking is defined %}
							<tr><td class="synapse-admin-text-muted">Thinking</td><td>Activé (budget : {{ recommendation.provider_options.thinking.budget_tokens }} tokens)</td></tr>
						{% endif %}
						{% if recommendation.rgpd_risk %}
							<tr><td class="synapse-admin-text-muted">RGPD</td><td>
								{% set rgpdBadge = {danger: 'danger', risk: 'warning', tolerated: 'info'} %}
								<span class="synapse-admin-badge synapse-admin-badge--{{ rgpdBadge[recommendation.rgpd_risk] ?? 'default' }}">{{ recommendation.rgpd_risk }}</span>
							</td></tr>
						{% endif %}
					</tbody>
				</table>

				<div class="synapse-admin-mt-md synapse-admin-p-md" style="background: var(--sa-bg-tertiary); border-radius: var(--sa-radius-md);">
					<div class="synapse-admin-text-xs synapse-admin-text-muted synapse-admin-mb-xs"><i data-lucide="info" style="width: 14px; height: 14px; vertical-align: -2px;"></i> Justification</div>
					<div class="synapse-admin-text-sm" style="white-space: pre-line;">{{ recommendation.justification }}</div>
				</div>
			</div>

			<div class="synapse-admin-card__footer">
				<div class="synapse-admin-flex synapse-admin-gap-md">
					{# Macro pour les hidden fields de création #}
					{% set hiddenFields %}
						<input type="hidden" name="_token" value="{{ csrf_token('synapse_preset_wizard_create') }}">
						<input type="hidden" name="name" value="{{ recommendation.suggested_name }}">
						<input type="hidden" name="key" value="{{ recommendation.suggested_key }}">
						<input type="hidden" name="provider" value="{{ recommendation.provider }}">
						<input type="hidden" name="model" value="{{ recommendation.model }}">
						<input type="hidden" name="temperature" value="{{ recommendation.temperature }}">
						<input type="hidden" name="top_p" value="{{ recommendation.top_p }}">
						{% if recommendation.top_k is not null %}<input type="hidden" name="top_k" value="{{ recommendation.top_k }}">{% endif %}
						{% if recommendation.max_output_tokens is not null %}<input type="hidden" name="max_output_tokens" value="{{ recommendation.max_output_tokens }}">{% endif %}
						{% if recommendation.streaming_enabled %}<input type="hidden" name="streaming_enabled" value="1">{% endif %}
						{% if recommendation.provider_options %}<input type="hidden" name="provider_options" value="{{ recommendation.provider_options|json_encode }}">{% endif %}
					{% endset %}

					<form action="{{ path('synapse_admin_presets_wizard_create') }}" method="POST">
						{{ hiddenFields|raw }}
						<button type="submit" class="synapse-admin-btn synapse-admin-btn--outline">
							<i data-lucide="plus"></i> Créer (inactif)
						</button>
					</form>

					<form action="{{ path('synapse_admin_presets_wizard_create') }}" method="POST">
						{{ hiddenFields|raw }}
						<input type="hidden" name="activate" value="1">
						<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
							<i data-lucide="zap"></i> Créer et activer
						</button>
					</form>

					<a href="{{ path('synapse_admin_presets_wizard') }}" class="synapse-admin-btn synapse-admin-btn--ghost">
						<i data-lucide="arrow-left"></i> Recommencer
					</a>
				</div>
			</div>
		</div>

	{% else %}
		{# ══════════════════════════════════════════════════════════════════════════ #}
		{# FORMULAIRE                                                                #}
		{# ══════════════════════════════════════════════════════════════════════════ #}

		<form action="{{ path('synapse_admin_presets_wizard_generate') }}" method="POST" id="wizard-form" style="max-width: 800px;">
			<input type="hidden" name="_token" value="{{ csrf_token('synapse_preset_wizard') }}">

			{# ── Choix du mode ───────────────────────────────────────────────────── #}
			<div class="synapse-admin-card synapse-admin-mb-lg">
				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
						<i data-lucide="compass"></i>
					</div>
					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
						<span class="synapse-admin-card__title">Comment voulez-vous procéder ?</span>
						<span class="synapse-admin-text-sm synapse-admin-text-muted">Choisissez le mode qui vous convient</span>
					</div>
				</div>
				<div class="synapse-admin-card__body">
					<div class="synapse-admin-grid synapse-admin-grid--2" style="gap: 12px;">
						{# Mode guidé #}
						<label class="synapse-admin-card synapse-admin-card--hover" style="cursor: pointer; padding: 20px;" data-wizard-mode>
							<input type="radio" name="wizard_mode" value="guided" style="display: none;">
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-md">
								<div class="synapse-admin-kpi__icon--primary" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: var(--sa-radius-md); flex-shrink: 0;">
									<i data-lucide="list-checks" style="width: 24px; height: 24px;"></i>
								</div>
								<div>
									<div class="synapse-admin-text-sm" style="font-weight: 700;">Mode guidé</div>
									<div class="synapse-admin-text-xs synapse-admin-text-muted">Répondez à quelques questions simples et on choisit pour vous</div>
								</div>
							</div>
						</label>

						{# Mode IA #}
						<label class="synapse-admin-card synapse-admin-card--hover" style="cursor: pointer; padding: 20px; {{ not has_active_preset ? 'opacity: 0.5; pointer-events: none;' : '' }}" data-wizard-mode>
							<input type="radio" name="wizard_mode" value="ai" style="display: none;" {{ not has_active_preset ? 'disabled' : '' }}>
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-md">
								<div class="synapse-admin-kpi__icon--primary" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: var(--sa-radius-md); flex-shrink: 0;">
									<i data-lucide="sparkles" style="width: 24px; height: 24px;"></i>
								</div>
								<div>
									<div class="synapse-admin-text-sm" style="font-weight: 700;">Mode IA</div>
									<div class="synapse-admin-text-xs synapse-admin-text-muted">
										{% if has_active_preset %}
											Décrivez votre besoin en langage naturel, l'IA choisit pour vous
										{% else %}
											Nécessite un preset actif — configurez-en un d'abord via le mode guidé
										{% endif %}
									</div>
								</div>
							</div>
						</label>
					</div>
				</div>
			</div>

			{# ── Contenu Mode IA ─────────────────────────────────────────────────── #}
			<div id="section-ai" style="display: none;">
				<div class="synapse-admin-card synapse-admin-mb-lg">
					<div class="synapse-admin-card__header">
						<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
							<i data-lucide="sparkles"></i>
						</div>
						<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
							<span class="synapse-admin-card__title">Décrivez votre besoin</span>
							<span class="synapse-admin-text-sm synapse-admin-text-muted">Expliquez en quelques phrases ce que vous voulez faire avec ce preset</span>
						</div>
					</div>
					<div class="synapse-admin-card__body">
						<textarea name="ai_description" rows="4" class="synapse-admin-input" placeholder="Ex : Je veux un modèle rapide et pas cher pour du support client, capable d'utiliser des outils. Les données des utilisateurs sont sensibles (RGPD)." style="width: 100%;"></textarea>
						<input type="hidden" name="ai_mode" value="">
					</div>
				</div>
			</div>

			{# ── Contenu Mode Guidé ──────────────────────────────────────────────── #}
			<div id="section-guided" style="display: none;">

				{# Cas d'usage #}
				<div class="synapse-admin-card synapse-admin-mb-lg">
					<div class="synapse-admin-card__header">
						<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
							<i data-lucide="target"></i>
						</div>
						<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
							<span class="synapse-admin-card__title">Quel est votre besoin ?</span>
							<span class="synapse-admin-text-sm synapse-admin-text-muted">Choisissez le type d'usage principal</span>
						</div>
					</div>
					<div class="synapse-admin-card__body">
						<div class="synapse-admin-grid synapse-admin-grid--2" style="gap: 12px;">
							{% set useCases = [
								{value: 'conversation', icon: 'message-square-text', label: 'Conversation', desc: 'Discuter, poser des questions, rédiger du texte'},
								{value: 'agents', icon: 'brain', label: 'Agents intelligents', desc: 'Tâches complexes, raisonnement, outils automatiques'},
								{value: 'image', icon: 'image', label: "Génération d'images", desc: "Créer et éditer des images à partir de texte"},
							] %}
							{% for uc in useCases %}
								<label class="synapse-admin-card synapse-admin-card--hover" style="cursor: pointer; padding: 16px; {{ uc.value == 'conversation' ? 'outline: 2px solid var(--sa-primary);' : '' }}" data-wizard-choice="usecase">
									<input type="radio" name="use_case" value="{{ uc.value }}" {{ uc.value == 'conversation' ? 'checked' : '' }} style="display: none;">
									<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-md">
										<div class="synapse-admin-kpi__icon--primary" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: var(--sa-radius-md); flex-shrink: 0;">
											<i data-lucide="{{ uc.icon }}"></i>
										</div>
										<div>
											<div class="synapse-admin-text-sm" style="font-weight: 600;">{{ uc.label }}</div>
											<div class="synapse-admin-text-xs synapse-admin-text-muted">{{ uc.desc }}</div>
										</div>
									</div>
								</label>
							{% endfor %}
						</div>
					</div>
				</div>

				{# Priorité #}
				<div class="synapse-admin-card synapse-admin-mb-lg">
					<div class="synapse-admin-card__header">
						<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
							<i data-lucide="gauge"></i>
						</div>
						<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs">
							<span class="synapse-admin-card__title">Quelle priorité ?</span>
							<span class="synapse-admin-text-sm synapse-admin-text-muted">Équilibrez qualité et coût selon vos besoins</span>
						</div>
					</div>
					<div class="synapse-admin-card__body">
						<div class="synapse-admin-flex synapse-admin-gap-md" style="flex-wrap: wrap;">
							{% set priorities = [
								{value: 'flagship', icon: 'crown', label: 'Qualité maximale', desc: 'Le meilleur modèle, peu importe le prix'},
								{value: 'balanced', icon: 'scale', label: 'Bon équilibre', desc: 'Qualité/prix optimal — recommandé'},
								{value: 'fast', icon: 'zap', label: 'Le plus économique', desc: 'Rapide et pas cher, pour le volume'},
							] %}
							{% for p in priorities %}
								<label class="synapse-admin-card synapse-admin-card--hover" style="cursor: pointer; padding: 12px 16px; flex: 1; min-width: 200px; {{ p.value == 'balanced' ? 'outline: 2px solid var(--sa-primary);' : '' }}" data-wizard-choice="priority">
									<input type="radio" name="priority" value="{{ p.value }}" {{ p.value == 'balanced' ? 'checked' : '' }} style="display: none;">
									<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm">
										<i data-lucide="{{ p.icon }}" style="width: 18px; height: 18px; flex-shrink: 0;"></i>
										<div>
											<div class="synapse-admin-text-sm" style="font-weight: 600;">{{ p.label }}</div>
											<div class="synapse-admin-text-xs synapse-admin-text-muted">{{ p.desc }}</div>
										</div>
									</div>
								</label>
							{% endfor %}
						</div>
					</div>
				</div>

				{# RGPD #}
				<div class="synapse-admin-card synapse-admin-mb-lg">
					<div class="synapse-admin-card__header">
						<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
							<i data-lucide="shield-check"></i>
						</div>
						<span class="synapse-admin-card__title">Conformité</span>
					</div>
					<div class="synapse-admin-card__body">
						<label class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm" style="cursor: pointer;">
							<input type="checkbox" name="rgpd_safe" value="1" class="synapse-admin-checkbox">
							<div>
								<span class="synapse-admin-text-sm" style="font-weight: 500;">Données sensibles (RGPD)</span>
								<div class="synapse-admin-text-xs synapse-admin-text-muted">Exclure les modèles à risque RGPD élevé</div>
							</div>
						</label>
					</div>
				</div>

			</div>

			{# ── Boutons ─────────────────────────────────────────────────────────── #}
			<div id="section-submit" class="synapse-admin-flex synapse-admin-gap-md" style="display: none;">
				<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
					<i data-lucide="wand-2"></i> Recommander un preset
				</button>
				<a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-btn synapse-admin-btn--ghost">
					Annuler
				</a>
			</div>
		</form>

	{% endif %}

	{# ── JavaScript ────────────────────────────────────────────────────────── #}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			var sectionGuided = document.getElementById('section-guided');
			var sectionAi = document.getElementById('section-ai');
			var sectionSubmit = document.getElementById('section-submit');

			// Gestion choix de mode (guidé vs IA)
			document.querySelectorAll('[data-wizard-mode]').forEach(function(label) {
				label.querySelector('input').addEventListener('change', function() {
					// Mise à jour visuelle des cartes mode
					document.querySelectorAll('[data-wizard-mode]').forEach(function(l) {
						l.style.outline = 'none';
					});
					if (this.checked) {
						label.style.outline = '2px solid var(--sa-primary)';
					}

					// Afficher le bouton submit
					sectionSubmit.style.display = 'flex';

					// Basculer les sections
					if (this.value === 'ai') {
						sectionGuided.style.display = 'none';
						sectionAi.style.display = 'block';
						sectionAi.querySelector('[name="ai_mode"]').value = '1';
					} else {
						sectionGuided.style.display = 'block';
						sectionAi.style.display = 'none';
						sectionAi.querySelector('[name="ai_mode"]').value = '';
					}
				});
			});

			// Gestion des cartes radio (use case + priority)
			document.querySelectorAll('[data-wizard-choice]').forEach(function(label) {
				label.querySelector('input').addEventListener('change', function() {
					var group = label.getAttribute('data-wizard-choice');
					document.querySelectorAll('[data-wizard-choice="' + group + '"]').forEach(function(l) {
						l.style.outline = 'none';
					});
					if (this.checked) {
						label.style.outline = '2px solid var(--sa-primary)';
					}
				});
			});

			// Écran de chargement au submit
			var wizardForm = document.getElementById('wizard-form');
			var wizardLoading = document.getElementById('wizard-loading');
			if (wizardForm && wizardLoading) {
				wizardForm.addEventListener('submit', function() {
					var isAi = wizardForm.querySelector('[name="wizard_mode"]:checked');
					var loadingTitle = document.getElementById('loading-title');
					var loadingSub = document.getElementById('loading-subtitle');

					if (isAi && isAi.value === 'ai') {
						loadingTitle.textContent = 'L\'IA réfléchit...';
						loadingSub.textContent = 'Analyse de vos besoins et sélection du meilleur modèle. Cela peut prendre quelques secondes.';
					} else {
						loadingTitle.textContent = 'Analyse en cours...';
						loadingSub.textContent = 'Sélection du meilleur modèle parmi vos providers configurés.';
					}

					wizardForm.style.display = 'none';
					wizardLoading.style.display = 'block';
				});
