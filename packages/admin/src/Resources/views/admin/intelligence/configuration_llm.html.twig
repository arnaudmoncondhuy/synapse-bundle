	{# ── Scripts (onglet Modèles uniquement) ──────────────────────────────────── #}
	{% if tab == 'modeles' %}
		<script>
			const activeFilters = new Set();
const FILTER_BTN_IDS = ['filter-thinking', 'filter-tools', 'filter-streaming', 'filter-safety', 'filter-vision', 'filter-jsonmode'];
let currentSort = {
col: null,
dir: 'asc'
};

function toggleFilter(cap, btn) {
if (activeFilters.has(cap)) {
activeFilters.delete(cap);
btn.classList.remove('synapse-admin-btn--outline');
btn.classList.add('synapse-admin-btn--ghost');
} else {
activeFilters.add(cap);
btn.classList.remove('synapse-admin-btn--ghost');
btn.classList.add('synapse-admin-btn--outline');
} applyFilters();
}

function applyFilters() {
document.querySelectorAll('.model-row').forEach(row => {
const show = [... activeFilters].every(cap => row.dataset[cap] === '1');
row.hidden = ! show;
const settingsRow = row.nextElementSibling;
if (settingsRow && settingsRow.classList.contains('settings-row') && ! show) {
settingsRow.hidden = true;
}
});
}

function resetFilters() {
activeFilters.clear();
FILTER_BTN_IDS.forEach(id => {
const btn = document.getElementById(id);
if (btn) {
btn.classList.remove('synapse-admin-btn--outline');
btn.classList.add('synapse-admin-btn--ghost');
}
});
document.querySelectorAll('.model-row').forEach(row => row.hidden = false);
}

// ── Tri de tableau ───────────────────────────────────────────────────────
function sortTable(col) {
const table = document.getElementById('table-models');
const tbody = table.querySelector('tbody');

// Toggle direction
if (currentSort.col === col) {
currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
} else {
currentSort.col = col;
currentSort.dir = 'asc';
}

// Update header icons
table.querySelectorAll('th.sortable').forEach(th => {
th.classList.remove('sort-asc', 'sort-desc');
const icon = th.querySelector('.sort-icon');
if (icon) 
icon.setAttribute('data-lucide', 'chevrons-up-down');

});
const activeTh = table.querySelector(`th[data-col="${col}"]`);
if (activeTh) {
activeTh.classList.add(currentSort.dir === 'asc' ? 'sort-asc' : 'sort-desc');
const icon = activeTh.querySelector('.sort-icon');
if (icon) 
icon.setAttribute('data-lucide', currentSort.dir === 'asc' ? 'chevron-up' : 'chevron-down');

}
if (typeof lucide !== 'undefined') 
lucide.createIcons();


// Collect pairs [model-row, settings-row]
const rows = [];
const allRows = [... tbody.children];
for (let i = 0; i < allRows.length; i++) {
if (allRows[i].classList.contains('model-row')) {
const next = allRows[i + 1];
const settings = (next && next.classList.contains('settings-row')) ? next : null;
rows.push({model: allRows[i], settings});
}
}

// Sort
rows.sort((a, b) => {
let va = a.model.dataset[col] || '';
let vb = b.model.dataset[col] || '';
if (col === 'pricing') {
va = parseFloat(va) || 0;
vb = parseFloat(vb) || 0;
return currentSort.dir === 'asc' ? va - vb : vb - va;
}
return currentSort.dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
});

// Re-append
rows.forEach(({model, settings}) => {
tbody.appendChild(model);
if (settings) 
tbody.appendChild(settings);

});
}

function toggleSettings(safeId) {
const row = document.getElementById('settings-' + safeId);
if (row)
row.hidden = ! row.hidden;

}

async function toggleModelStatus(badge) {
if (badge.dataset.toggling) return;
badge.dataset.toggling = '1';
badge.style.opacity = '0.5';

const url = badge.dataset.toggleUrl;
const token = badge.dataset.toggleToken;

const formData = new FormData();
formData.append('_token', token);

try {
const resp = await fetch(url, {
method: 'POST',
body: formData,
headers: {'X-Requested-With': 'XMLHttpRequest'}
});

if (!resp.ok) throw new Error(resp.statusText);
const data = await resp.json();
const nowEnabled = data.enabled;

badge.dataset.toggleEnabled = nowEnabled ? '1' : '0';
if (data.token) badge.dataset.toggleToken = data.token;

badge.className = 'synapse-admin-badge ' + (nowEnabled ? 'synapse-admin-badge--success' : 'synapse-admin-badge--neutral');
badge.style.cursor = 'pointer';

const icon = badge.querySelector('[data-lucide]');
if (icon) icon.setAttribute('data-lucide', nowEnabled ? 'circle-check' : 'circle-slash');

const label = badge.querySelector('.status-label');
if (label) label.textContent = nowEnabled ? '{{ 'synapse.admin.llm_config.provider.status.active'|trans(domain='synapse_admin') }}' : '{{ 'synapse.admin.llm_config.provider.status.disabled'|trans(domain='synapse_admin') }}';

if (typeof lucide !== 'undefined') lucide.createIcons();
} catch (e) {
console.error('Toggle failed:', e);
window.location.reload();
} finally {
delete badge.dataset.toggling;
badge.style.opacity = '';
}
}

document.querySelectorAll('[data-toggle-url]').forEach(badge => {
badge.addEventListener('click', () => toggleModelStatus(badge));
});
		</script>
	{% endif %}

	{# ── Script: Test Provider ──────────────────────────────────────────────── #}
	<script>
		async function testProvider(providerId, btn) {
const originalHtml = btn.innerHTML;
const originalDisabled = btn.disabled;
btn.disabled = true;

// Get CSRF token from button's data attribute
const csrfToken = btn.getAttribute('data-csrf-token') || '';

try {
const formData = new FormData();
if (csrfToken) {
formData.append('_token', csrfToken);
}

const response = await fetch('{{ path('synapse_admin_providers_test', {'id': 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', providerId), {
method: 'POST',
headers: {
'X-Requested-With': 'XMLHttpRequest'
},
body: formData
});

const data = await response.json();

if (data.success) {
btn.innerHTML = '<i data-lucide="check-circle-2" style="color: #16a34a"></i> ✓ OK';
btn.style.backgroundColor = '#dcfce7';
btn.style.color = '#166534';
setTimeout(() => {
btn.innerHTML = originalHtml;
btn.disabled = originalDisabled;
btn.style.backgroundColor = '';
btn.style.color = '';
lucide.createIcons();
}, 3000);
} else {
btn.innerHTML = '<i data-lucide="alert-circle" style="color: #dc2626"></i> ✗ Erreur';
btn.style.backgroundColor = '#fee2e2';
btn.style.color = '#7f1d1d';
setTimeout(() => {
btn.innerHTML = originalHtml;
btn.disabled = originalDisabled;
btn.style.backgroundColor = '';
btn.style.color = '';
lucide.createIcons();
}, 3000);
if (data.error) {
alert('Erreur: ' + data.error);
}
}
} catch (error) {
btn.innerHTML = '<i data-lucide="alert-circle" style="color: #dc2626"></i> ✗ Erreur';
btn.style.backgroundColor = '#fee2e2';
btn.style.color = '#7f1d1d';
setTimeout(() => {
btn.innerHTML = originalHtml;
btn.disabled = originalDisabled;
btn.style.backgroundColor = '';
btn.style.color = '';
lucide.createIcons();
}, 3000);
console.error('Test failed:', error);
}
}
	</script>

