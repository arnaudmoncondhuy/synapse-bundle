{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.agent.list.page_title'|trans(domain='synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_providers') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-current">{{ 'synapse.admin.sidebar.agents'|trans(domain='synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="target"></i>
				</span>
				{{ 'synapse.admin.agent.list.title'|trans(domain='synapse_admin') }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ 'synapse.admin.agent.list.subtitle'|trans(domain='synapse_admin') }}
				{{ 'synapse.admin.agent.list.usage_tip'|trans(domain='synapse_admin')|raw }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_agents_new') }}" class="synapse-admin-btn synapse-admin-btn--primary">
				<i data-lucide="plus"></i>
				{{ 'synapse.admin.agent.list.action.new'|trans(domain='synapse_admin') }}
			</a>
		</div>
	</div>

	<div class="synapse-admin-grid synapse-admin-grid--2">
		{% for agent in agents %}
			<div class="synapse-admin-card synapse-admin-card--hover {{ not agent.isActive ? 'synapse-admin-card--inactive' : '' }}">

				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary" style="font-size: 1.5rem; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center;">
						{{ agent.emoji }}
					</div>

					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm">
						<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm">
							<span class="synapse-admin-card__title">{{ agent.name }}</span>
							{% if agent.isBuiltin %}
								<span class="synapse-admin-badge synapse-admin-badge--neutral" data-synapse-admin-tooltip="{{ 'synapse.admin.agent.list.badge.builtin_tooltip'|trans(domain='synapse_admin') }}">
									<i data-lucide="lock"></i>
									{{ 'synapse.admin.agent.list.badge.builtin'|trans(domain='synapse_admin') }}
								</span>
							{% endif %}
							{% if not agent.isActive %}
								<span class="synapse-admin-badge synapse-admin-badge--warning">
									<i data-lucide="eye-off"></i>
									{{ 'synapse.admin.agent.list.badge.disabled'|trans(domain='synapse_admin') }}
								</span>
							{% endif %}
						</div>
						<div class="synapse-admin-text-sm synapse-admin-text-muted">
							<code class="synapse-admin-font-mono" style="font-size: 0.75rem;">{{ agent.key }}</code>
						</div>
					</div>
				</div>

				<div class="synapse-admin-card__body synapse-admin-card__body--compact">
					<p class="synapse-admin-text-sm synapse-admin-text-muted synapse-admin-mb-md">{{ agent.description }}</p>

					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm synapse-admin-text-xs synapse-admin-text-muted">
						{% if agent.modelPreset %}
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
								<i data-lucide="cpu" style="width: 1rem; height: 1rem;"></i>
								<span><strong>{{ 'synapse.admin.agent.list.label.model'|trans(domain='synapse_admin') }} :</strong> {{ agent.modelPreset.name }}</span>
							</div>
						{% endif %}
						{% if agent.tone %}
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
								<i data-lucide="mic-2" style="width: 1rem; height: 1rem;"></i>
								<span><strong>{{ 'synapse.admin.agent.list.label.style'|trans(domain='synapse_admin') }} :</strong> {{ agent.tone.emoji }} {{ agent.tone.name }}</span>
							</div>
						{% endif %}
						{% if agent.allowedToolNames|default([])|length > 0 %}
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
								<i data-lucide="wrench" style="width: 1rem; height: 1rem;"></i>
								<span><strong>{{ 'synapse.admin.agent.list.label.tools'|trans(domain='synapse_admin') }} :</strong> {{ 'synapse.admin.agent.list.tools_count'|trans({'count': agent.allowedToolNames|length}, domain='synapse_admin') }}</span>
							</div>
						{% endif %}
					</div>

					<details class="synapse-admin-collapsible" style="margin-top: 1rem;">
						<summary class="synapse-admin-collapsible__summary">
							<div class="synapse-admin-collapsible__icon">
								<i data-lucide="file-text"></i>
							</div>
							<div class="synapse-admin-collapsible__title">
								{{ 'synapse.admin.agent.list.label.system_prompt'|trans(domain='synapse_admin') }}
								<div class="synapse-admin-collapsible__subtitle">
									{{ agent.systemPrompt|slice(0, 60) ~ '…' }}
								</div>
							</div>
							<i data-lucide="chevron-down" class="synapse-admin-collapsible__chevron"></i>
						</summary>
						<div class="synapse-admin-collapsible__content">
							<p class="synapse-admin-text-sm synapse-admin-font-mono" style="white-space: pre-wrap; word-break: break-word;">{{ agent.systemPrompt }}</p>
						</div>
					</details>
				</div>

				<div class="synapse-admin-card__footer" style="overflow: visible;">
					<div class="synapse-admin-flex synapse-admin-gap-md synapse-admin-items-center" style="position: relative; z-index: 10;">

						{# Modifier #}
						<a href="{{ path('synapse_admin_agents_edit', {id: agent.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm" data-synapse-admin-tooltip="{{ 'synapse.admin.agent.list.tooltip.edit'|trans(domain='synapse_admin') }}">
							<i data-lucide="edit-3"></i>
						</a>

						{# Activer / Désactiver #}
						<form action="{{ path('synapse_admin_agents_toggle', {id: agent.id}) }}" method="POST" class="synapse-admin-form-inline">
							<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_toggle_' ~ agent.id) }}">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm"
									data-synapse-admin-tooltip="{{ agent.isActive ? 'synapse.admin.agent.list.tooltip.disable'|trans(domain='synapse_admin') : 'synapse.admin.agent.list.tooltip.enable'|trans(domain='synapse_admin') }}">
								{% if agent.isActive %}
									<i data-lucide="eye-off"></i>
								{% else %}
									<i data-lucide="eye"></i>
								{% endif %}
							</button>
						</form>

						{# Supprimer (masqué ou désactivé si builtin) #}
						<form action="{{ path('synapse_admin_agents_delete', {id: agent.id}) }}" method="POST" class="synapse-admin-form-inline"
							{% if not agent.isBuiltin %}onsubmit="return confirm('{{ 'synapse.admin.agent.list.confirm_delete'|trans({'name': agent.name}, domain='synapse_admin')|escape('js') }}')"{% endif %}>
							<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_delete_' ~ agent.id) }}">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm synapse-admin-text-danger"
									data-synapse-admin-tooltip="{{ agent.isBuiltin ? 'synapse.admin.agent.list.tooltip.builtin_no_delete'|trans(domain='synapse_admin') : 'synapse.admin.agent.list.tooltip.delete'|trans(domain='synapse_admin') }}"
									{% if agent.isBuiltin %}disabled{% endif %}>
								<i data-lucide="trash-2"></i>
							</button>
						</form>

					</div>
				</div>

			</div>
		{% else %}
			<div class="synapse-admin-empty-state" style="grid-column: 1 / -1;">
				<i data-lucide="target" class="synapse-admin-empty-state__icon"></i>
				<p class="synapse-admin-empty-state__title">{{ 'synapse.admin.agent.list.empty.title'|trans(domain='synapse_admin') }}</p>
				<p class="synapse-admin-empty-state__subtitle">{{ 'synapse.admin.agent.list.empty.subtitle'|trans(domain='synapse_admin') }}</p>
				<a href="{{ path('synapse_admin_agents_new') }}" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-mt-md">
					<i data-lucide="plus"></i>
					{{ 'synapse.admin.agent.list.empty.action'|trans(domain='synapse_admin') }}
				</a>
			</div>
		{% endfor %}
	</div>

{% endblock %}
