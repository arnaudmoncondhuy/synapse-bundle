{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}
	{{ is_new ? 'Nouveau profil d\'agent' : 'Éditer l\'agent : ' ~ agent.name }}
	| Intelligence | Synapse Administration Synapse
{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="#" class="synapse-admin-topbar__breadcrumb">Intelligence</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-topbar__breadcrumb">Agents</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">{{ is_new ? 'Nouveau' : agent.name }}</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="target"></i>
				</span>
				{{ is_new ? 'Nouveau profil d\'agent' : 'Modifier l\'agent : ' ~ agent.name }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ is_new
				? 'Créez un agent qui combine un prompt système, un modèle LLM et un ton spécifique.'
				: 'Modifiez la configuration de cet agent. Les changements s\'appliquent immédiatement.' }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
				<i data-lucide="arrow-left"></i>
				Retour à la liste
			</a>
		</div>
	</div>

	<form method="post" action="{{ is_new ? path('synapse_admin_agents_new') : path('synapse_admin_agents_edit', {id: agent.id}) }}">

		<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_edit') }}">

		{# ── Identification ────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="tag"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Identification</div>
					<div class="synapse-admin-card__subtitle">Nom, emoji et clé technique de l'agent</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-md">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-emoji">Emoji</label>
						<input type="text" id="agent-emoji" name="emoji" value="{{ agent.emoji }}"
							class="synapse-admin-input" placeholder="🎯" maxlength="10">
					</div>

					<div class="synapse-admin-form-group" style="grid-column: span 2;">
						<label class="synapse-admin-label" for="agent-name">
							Nom de l'agent <span class="synapse-admin-required">*</span>
						</label>
						<input type="text" id="agent-name" name="name" value="{{ agent.name }}"
							class="synapse-admin-input" required placeholder="Ex : Assistant Support">
					</div>

				</div>

				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-key">
						Clé technique (slug) <span class="synapse-admin-required">*</span>
						{% if agent.isBuiltin %}
							<span class="synapse-admin-badge synapse-admin-badge--neutral synapse-admin-ml-sm" data-synapse-admin-tooltip="La clé d'un agent intégré ne peut pas être modifiée">
								<i data-lucide="lock"></i>
								Verrouillée
							</span>
						{% endif %}
					</label>
					<input type="text" id="agent-key" name="key" value="{{ agent.key }}"
						class="synapse-admin-input synapse-admin-font-mono"
						{{ agent.isBuiltin ? 'readonly' : '' }}
						required placeholder="ex: support_client"
						pattern="[a-z0-9_]+" title="Lettres minuscules, chiffres et tirets bas uniquement">
					<p class="synapse-admin-help-text">Utilisée pour l'invocation : <code>ChatService::ask('...', ['agent' => '{{ agent.key ?: 'mon_agent' }}'])</code></p>
				</div>

			</div>
		</div>

		{# ── Description ──────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="info"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Description</div>
					<div class="synapse-admin-card__subtitle">Usage et rôle de cet agent</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-description">Description courte <span class="synapse-admin-required">*</span></label>
					<textarea id="agent-description" name="description" class="synapse-admin-input synapse-admin-textarea" rows="2" required
						placeholder="Ex : Agent spécialisé dans l'analyse de code et la correction d'erreurs.">{{ agent.description }}</textarea>
				</div>
			</div>
		</div>

		{# ── Prompt système ───────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="file-text"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Cœur de l'agent (System Prompt)</div>
					<div class="synapse-admin-card__subtitle">Instructions fondamentales définissant la personnalité et les limites</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-alert synapse-admin-alert--info synapse-admin-mb-md">
					<i data-lucide="info"></i>
					<span>Ce texte définit le comportement principal. Si un ton est sélectionné plus bas, ses instructions seront concaténées à ce prompt.</span>
				</div>

				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-system-prompt">Prompt système <span class="synapse-admin-required">*</span></label>
					<textarea id="agent-system-prompt" name="system_prompt" class="synapse-admin-input synapse-admin-textarea synapse-admin-font-mono" rows="10" required
						placeholder="Tu es un agent expert en...">{{ agent.systemPrompt }}</textarea>
				</div>

			</div>
		</div>

		{# ── Configuration ─────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="settings"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Intelligence</div>
					<div class="synapse-admin-card__subtitle">Modèle LLM et style de réponse</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-lg">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-model-preset">
							Preset de modèle LLM
						</label>
						<select id="agent-model-preset" name="model_preset_id" class="synapse-admin-input">
							<option value="">— Utiliser le preset actif par défaut —</option>
							{% for preset in presets %}
								<option value="{{ preset.id }}" {% if agent.modelPreset and agent.modelPreset.id == preset.id %}selected{% endif %}>
									{{ preset.name }} ({{ preset.model }})
								</option>
							{% endfor %}
						</select>
						<p class="synapse-admin-help-text">Force ce profil à utiliser un modèle spécifique.</p>
					</div>

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-tone">
							Ton de réponse
						</label>
						<select id="agent-tone" name="tone_id" class="synapse-admin-input">
							<option value="">— Pas de ton particulier —</option>
							{% for tone in tones %}
								<option value="{{ tone.id }}" {% if agent.tone and agent.tone.id == tone.id %}selected{% endif %}>
									{{ tone.emoji }} {{ tone.name }}
								</option>
							{% endfor %}
						</select>
						<p class="synapse-admin-help-text">Ajoute des instructions de style (ex: formel, concis, humoristique).</p>
					</div>

				</div>

			</div>
		</div>

		{# ── Paramètres ───────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="settings-2"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Paramètres</div>
					<div class="synapse-admin-card__subtitle">Visibilité et priorité</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--2">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-sort-order">Priorité d'affichage</label>
						<input type="number" id="agent-sort-order" name="sort_order" value="{{ agent.sortOrder }}"
							class="synapse-admin-input" min="0" max="999" placeholder="0">
						<p class="synapse-admin-help-text">De 0 à 999. Les plus petits sont affichés en haut de liste.</p>
					</div>

					<div class="synapse-admin-form-group">
						<div class="synapse-admin-label">Statut</div>
						<label class="synapse-admin-toggle">
							<input type="checkbox" name="is_active" id="agent-is-active" {{ agent.isActive ? 'checked' : '' }}>
							<span class="synapse-admin-toggle__slider"></span>
							<span class="synapse-admin-toggle__label">Activer cet agent</span>
						</label>
					</div>

				</div>

			</div>
		</div>

		{# ── Limite de dépense (agent) ───────── #}
		{% if not is_new and (spending_limit is defined) %}
			<div class="synapse-admin-card synapse-admin-mb-lg">
				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--warning">
						<i data-lucide="gauge"></i>
					</div>
					<div>
						<div class="synapse-admin-card__title">Contrôle des coûts</div>
						<div class="synapse-admin-card__subtitle">Définissez un plafond de budget spécifique pour cet agent</div>
					</div>
				</div>
				<div class="synapse-admin-card__body synapse-admin-card__body--compact">
					<form method="post" action="{{ path('synapse_admin_agents_limit', {id: agent.id}) }}">
						<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_limit_' ~ agent.id) }}">
						<input type="hidden" name="action" value="save">

						<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-mb-md">
							<div class="synapse-admin-form-group">
								<label class="synapse-admin-label" for="limit-amount">Budget maximum</label>
								<input type="text" id="limit-amount" name="amount" class="synapse-admin-input" placeholder="10.00" value="{{ spending_limit.amount ?? '' }}" required>
							</div>
							<div class="synapse-admin-form-group">
								<label class="synapse-admin-label" for="limit-currency">Devise</label>
								<input type="text" id="limit-currency" name="currency" class="synapse-admin-input" value="{{ spending_limit.currency ?? 'EUR' }}" maxlength="3">
							</div>
						</div>
						<div class="synapse-admin-form-group synapse-admin-mb-md">
							<label class="synapse-admin-label" for="limit-period">Fenêtre temporelle</label>
							<select id="limit-period" name="period" class="synapse-admin-input">
								{% for key, label in periods|default([]) %}
									<option value="{{ key }}" {{ (spending_limit.period.value ?? '') == key ? 'selected' : '' }}>{{ label }}</option>
								{% endfor %}
							</select>
						</div>
						<div class="synapse-admin-form-group synapse-admin-mb-md">
							<label class="synapse-admin-label" for="limit-name">Libellé de la limite (optionnel)</label>
							<input type="text" id="limit-name" name="name" class="synapse-admin-input" placeholder="Ex : Budget mensuel support" value="{{ spending_limit.name ?? '' }}">
						</div>
						<div class="synapse-admin-flex synapse-admin-gap-md">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
								<i data-lucide="save"></i>
								{{ spending_limit ? 'Mettre à jour le plafond' : 'Activer un plafond' }}
							</button>
							{% if spending_limit %}
								<button type="submit" name="action" value="delete" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-text-danger" formaction="{{ path('synapse_admin_agents_limit', {id: agent.id}) }}" onclick="return confirm('Retirer le plafond de coût pour cet agent ?');">
									<i data-lucide="trash-2"></i>
									Supprimer
								</button>
							{% endif %}
						</div>
					</form>
				</div>
			</div>
		{% endif %}

		{# ── Actions ─────────────────────────────────────────────────────────── #}
		<div class="synapse-admin-flex synapse-admin-gap-md synapse-admin-justify-end synapse-admin-mb-xl">
			<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-btn synapse-admin-btn--ghost">
				Annuler
			</a>
			<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
				<i data-lucide="save"></i>
				{{ is_new ? 'Créer l\'agent' : 'Enregistrer les modifications' }}
			</button>
		</div>

	</form>
{% endblock %}
