{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}
	{{ is_new ? 'synapse.admin.agent.edit.page_title.new'|trans(domain='synapse_admin') : 'synapse.admin.agent.edit.page_title.edit'|trans({'%name%': agent.name}, domain='synapse_admin') }}
	| {{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }} | Synapse Administration Synapse
{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.agents'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">{{ is_new ? 'synapse.admin.common.new'|trans(domain='synapse_admin') : agent.name }}</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="target"></i>
				</span>
				{{ is_new ? 'synapse.admin.agent.edit.title.new'|trans(domain='synapse_admin') : 'synapse.admin.agent.edit.title.edit'|trans({'%name%': agent.name}, domain='synapse_admin') }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ is_new
				? 'synapse.admin.agent.edit.subtitle.new'|trans(domain='synapse_admin')
				: 'synapse.admin.agent.edit.subtitle.edit'|trans(domain='synapse_admin') }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
				<i data-lucide="arrow-left"></i>
				{{ 'synapse.admin.agent.edit.action.back'|trans(domain='synapse_admin') }}
			</a>
		</div>
	</div>

	<form method="post" action="{{ is_new ? path('synapse_admin_agents_new') : path('synapse_admin_agents_edit', {id: agent.id}) }}">

		<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_edit') }}">

		{# ── Identification ────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="tag"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.edit.section.id.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.id.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-md">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-emoji">{{ 'synapse.admin.agent.edit.label.emoji'|trans(domain='synapse_admin') }}</label>
						<input type="text" id="agent-emoji" name="emoji" value="{{ agent.emoji }}"
							class="synapse-admin-input" placeholder="🎯" maxlength="10">
					</div>

					<div class="synapse-admin-form-group" style="grid-column: span 2;">
						<label class="synapse-admin-label" for="agent-name">
							{{ 'synapse.admin.agent.edit.label.name'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span>
						</label>
						<input type="text" id="agent-name" name="name" value="{{ agent.name }}"
							class="synapse-admin-input" required placeholder="{{ 'synapse.admin.agent.edit.placeholder.name'|trans(domain='synapse_admin') }}">
					</div>

				</div>

				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-key">
						{{ 'synapse.admin.agent.edit.label.key'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span>
						{% if agent.isBuiltin %}
							<span class="synapse-admin-badge synapse-admin-badge--neutral synapse-admin-ml-sm" data-synapse-admin-tooltip="{{ 'synapse.admin.agent.edit.tooltip.key_locked'|trans(domain='synapse_admin') }}">
								<i data-lucide="lock"></i>
								{{ 'synapse.admin.agent.edit.badge.locked'|trans(domain='synapse_admin') }}
							</span>
						{% endif %}
					</label>
					<input type="text" id="agent-key" name="key" value="{{ agent.key }}"
						class="synapse-admin-input synapse-admin-font-mono"
						{{ agent.isBuiltin ? 'readonly' : '' }}
						required placeholder="ex: support_client"
						pattern="[a-z0-9_]+" title="{{ 'synapse.admin.agent.edit.pattern_title'|trans(domain='synapse_admin') }}">
					<p class="synapse-admin-help-text">{{ 'synapse.admin.agent.edit.usage_tip'|trans({'%key%': agent.key ?: 'mon_agent'}, domain='synapse_admin')|raw }}</p>
				</div>

			</div>
		</div>

		{# ── Description ──────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="info"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.edit.section.description.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.description.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-description">{{ 'synapse.admin.agent.edit.label.description'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span></label>
					<textarea id="agent-description" name="description" class="synapse-admin-input synapse-admin-textarea" rows="2" required
						placeholder="{{ 'synapse.admin.agent.edit.placeholder.description'|trans(domain='synapse_admin') }}">{{ agent.description }}</textarea>
				</div>
			</div>
		</div>

		{# ── Prompt système ───────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="file-text"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.edit.section.prompt.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.prompt.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-alert synapse-admin-alert--info synapse-admin-mb-md">
					<i data-lucide="info"></i>
					<span>{{ 'synapse.admin.agent.edit.alert.prompt_tip'|trans(domain='synapse_admin') }}</span>
				</div>

				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="agent-system-prompt">{{ 'synapse.admin.agent.edit.label.system_prompt'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span></label>
					<textarea id="agent-system-prompt" name="system_prompt" class="synapse-admin-input synapse-admin-textarea synapse-admin-font-mono" rows="10" required
						placeholder="{{ 'synapse.admin.agent.edit.placeholder.prompt'|trans(domain='synapse_admin') }}">{{ agent.systemPrompt }}</textarea>
				</div>

			</div>
		</div>

		{# ── Configuration ─────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="settings"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.edit.section.config.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.config.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-lg">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-model-preset">
							{{ 'synapse.admin.agent.edit.label.model_preset'|trans(domain='synapse_admin') }}
						</label>
						<select id="agent-model-preset" name="model_preset_id" class="synapse-admin-input">
							<option value="">— {{ 'synapse.admin.agent.edit.option.default_preset'|trans(domain='synapse_admin') }} —</option>
							{% for preset in presets %}
								<option value="{{ preset.id }}" {% if agent.modelPreset and agent.modelPreset.id == preset.id %}selected{% endif %}>
									{{ preset.name }} ({{ preset.model }})
								</option>
							{% endfor %}
						</select>
						<p class="synapse-admin-help-text">{{ 'synapse.admin.agent.edit.help.model_preset'|trans(domain='synapse_admin') }}</p>
					</div>

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-tone">
							{{ 'synapse.admin.agent.edit.label.tone'|trans(domain='synapse_admin') }}
						</label>
						<select id="agent-tone" name="tone_id" class="synapse-admin-input">
							<option value="">— {{ 'synapse.admin.agent.edit.option.no_tone'|trans(domain='synapse_admin') }} —</option>
							{% for tone in tones %}
								<option value="{{ tone.id }}" {% if agent.tone and agent.tone.id == tone.id %}selected{% endif %}>
									{{ tone.emoji }} {{ tone.name }}
								</option>
							{% endfor %}
						</select>
						<p class="synapse-admin-help-text">{{ 'synapse.admin.agent.edit.help.tone'|trans(domain='synapse_admin') }}</p>
					</div>

				</div>

			</div>
		</div>

		{# ── Outils autorisés ─────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="wrench"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.list.label.tools'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.tools.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-alert synapse-admin-alert--info synapse-admin-mb-md">
					<i data-lucide="info"></i>
					<span>{{ 'synapse.admin.agent.edit.alert.tools_tip'|trans(domain='synapse_admin') }}</span>
				</div>

				{% if available_tools|default([])|length > 0 %}
					<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-sm">
						{% for tool in available_tools %}
							<label class="synapse-admin-toggle" style="align-items: flex-start;">
								<input type="checkbox"
									name="allowed_tools[]"
									value="{{ tool.name }}"
									{{ tool.name in (agent.allowedToolNames|default([])) ? 'checked' : '' }}>
								<span class="synapse-admin-toggle__slider"></span>
								<span class="synapse-admin-toggle__label">
									<strong class="synapse-admin-font-mono">{{ tool.name }}</strong><br>
									<span class="synapse-admin-text-sm synapse-admin-text-muted">
										{{ tool.description|length > 100 ? tool.description|slice(0, 100) ~ '…' : tool.description }}
									</span>
								</span>
							</label>
						{% endfor %}
					</div>
				{% else %}
					<p class="synapse-admin-text-muted synapse-admin-text-sm">{{ 'synapse.admin.agent.edit.no_tools'|trans(domain='synapse_admin') }}</p>
				{% endif %}

			</div>
		</div>

		{# ── Paramètres ───────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="settings-2"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.sidebar.settings'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.settings.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-grid synapse-admin-grid--2">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="agent-sort-order">{{ 'synapse.admin.agent.edit.label.sort_order'|trans(domain='synapse_admin') }}</label>
						<input type="number" id="agent-sort-order" name="sort_order" value="{{ agent.sortOrder }}"
							class="synapse-admin-input" min="0" max="999" placeholder="0">
						<p class="synapse-admin-help-text">{{ 'synapse.admin.agent.edit.help.sort_order'|trans(domain='synapse_admin') }}</p>
					</div>

					<div class="synapse-admin-form-group">
						<div class="synapse-admin-label">{{ 'synapse.admin.agent.edit.label.status'|trans(domain='synapse_admin') }}</div>
						<label class="synapse-admin-toggle">
							<input type="checkbox" name="is_active" id="agent-is-active" {{ agent.isActive ? 'checked' : '' }}>
							<span class="synapse-admin-toggle__slider"></span>
							<span class="synapse-admin-toggle__label">{{ 'synapse.admin.agent.edit.label.activate'|trans(domain='synapse_admin') }}</span>
						</label>
					</div>

				</div>

			</div>
		</div>


		{# ── Actions ─────────────────────────────────────────────────────────── #}
		<div class="synapse-admin-flex synapse-admin-gap-md synapse-admin-justify-end synapse-admin-mb-xl">
			<a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-btn synapse-admin-btn--ghost">
				{{ 'synapse.admin.common.cancel'|trans(domain='synapse_admin') }}
			</a>
			<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
				<i data-lucide="save"></i>
				{{ is_new ? 'synapse.admin.agent.edit.action.create'|trans(domain='synapse_admin') : 'synapse.admin.agent.edit.action.save'|trans(domain='synapse_admin') }}
			</button>
		</div>

	</form>

		{# ── Limite de dépense (agent) ───────── #}
		{% if not is_new and (spending_limit is defined) %}
			<div class="synapse-admin-card synapse-admin-mb-lg">
				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--warning">
						<i data-lucide="gauge"></i>
					</div>
					<div>
						<div class="synapse-admin-card__title">{{ 'synapse.admin.agent.edit.section.costs.title'|trans(domain='synapse_admin') }}</div>
						<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.agent.edit.section.costs.subtitle'|trans(domain='synapse_admin') }}</div>
					</div>
				</div>
				<div class="synapse-admin-card__body synapse-admin-card__body--compact">
					<form method="post" action="{{ path('synapse_admin_agents_limit', {id: agent.id}) }}">
						<input type="hidden" name="_token" value="{{ csrf_token('synapse_agent_limit_' ~ agent.id) }}">
						<input type="hidden" name="action" value="save">

						<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-mb-md">
							<div class="synapse-admin-form-group">
								<label class="synapse-admin-label" for="limit-amount">{{ 'synapse.admin.agent.edit.label.max_budget'|trans(domain='synapse_admin') }}</label>
								<input type="text" id="limit-amount" name="amount" class="synapse-admin-input" placeholder="10.00" value="{{ spending_limit.amount ?? '' }}" required>
							</div>
							<div class="synapse-admin-form-group">
								<label class="synapse-admin-label" for="limit-currency">{{ 'synapse.admin.agent.edit.label.currency'|trans(domain='synapse_admin') }}</label>
								<input type="text" id="limit-currency" name="currency" class="synapse-admin-input" value="{{ spending_limit.currency ?? 'EUR' }}" maxlength="3">
							</div>
						</div>
						<div class="synapse-admin-form-group synapse-admin-mb-md">
							<label class="synapse-admin-label" for="limit-period">{{ 'synapse.admin.agent.edit.label.time_window'|trans(domain='synapse_admin') }}</label>
							<select id="limit-period" name="period" class="synapse-admin-input">
								{% for key, label in periods|default([]) %}
									<option value="{{ key }}" {{ (spending_limit.period.value ?? '') == key ? 'selected' : '' }}>{{ label }}</option>
								{% endfor %}
							</select>
						</div>
						<div class="synapse-admin-form-group synapse-admin-mb-md">
							<label class="synapse-admin-label" for="limit-name">{{ 'synapse.admin.agent.edit.label.limit_label'|trans(domain='synapse_admin') }}</label>
							<input type="text" id="limit-name" name="name" class="synapse-admin-input" placeholder="{{ 'synapse.admin.agent.edit.placeholder.limit_label'|trans(domain='synapse_admin') }}" value="{{ spending_limit.name ?? '' }}">
						</div>
						<div class="synapse-admin-flex synapse-admin-gap-md">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary">
								<i data-lucide="save"></i>
								{{ spending_limit ? 'synapse.admin.agent.edit.action.update_limit'|trans(domain='synapse_admin') : 'synapse.admin.agent.edit.action.enable_limit'|trans(domain='synapse_admin') }}
							</button>
							{% if spending_limit %}
								<button type="submit" name="action" value="delete" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-text-danger" formaction="{{ path('synapse_admin_agents_limit', {id: agent.id}) }}" onclick="return confirm('{{ 'synapse.admin.agent.edit.confirm_remove_limit'|trans(domain='synapse_admin')|escape('js') }}');">
									<i data-lucide="trash-2"></i>
									{{ 'synapse.admin.common.delete'|trans(domain='synapse_admin') }}
								</button>
							{% endif %}
						</div>
					</form>
				</div>
			</div>
		{% endif %}
{% endblock %}
