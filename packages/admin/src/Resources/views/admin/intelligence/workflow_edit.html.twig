{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}
    {{ is_new ? 'synapse.admin.workflow.edit.page_title.new'|trans(domain: 'synapse_admin') : 'synapse.admin.workflow.edit.page_title.edit'|trans({name: workflow.name}, domain: 'synapse_admin') }}
{% endblock %}

{% block admin_breadcrumb %}
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="{{ path('synapse_admin_workflows') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.workflows'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <span class="synapse-admin-current">{{ is_new ? 'synapse.admin.common.new'|trans(domain: 'synapse_admin') : workflow.name }}</span>
{% endblock %}

{% block admin_content %}

    <div class="synapse-admin-page-header">
        <div class="synapse-admin-page-header__info">
            <h1 class="synapse-admin-page-title">
                <span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="workflow"></i>
                </span>
                {{ is_new
                    ? 'synapse.admin.workflow.edit.title.new'|trans(domain: 'synapse_admin')
                    : 'synapse.admin.workflow.edit.title.edit'|trans({name: workflow.name}, domain: 'synapse_admin') }}
            </h1>
            <p class="synapse-admin-page-subtitle">
                {{ is_new
                    ? 'synapse.admin.workflow.edit.subtitle.new'|trans(domain: 'synapse_admin')
                    : 'synapse.admin.workflow.edit.subtitle.edit'|trans(domain: 'synapse_admin') }}
            </p>
        </div>
        <div class="synapse-admin-page-header__actions">
            <a href="{{ path('synapse_admin_workflows') }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                <i data-lucide="x"></i>
                {{ 'synapse.admin.common.cancel'|trans(domain: 'synapse_admin') }}
            </a>
            <button type="submit" form="workflow-form" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
                <i data-lucide="save"></i>
                {{ is_new ? 'synapse.admin.workflow.edit.action.create'|trans(domain: 'synapse_admin') : 'synapse.admin.workflow.edit.action.save'|trans(domain: 'synapse_admin') }}
            </button>
        </div>
    </div>

    <form id="workflow-form" method="post" action="{{ is_new ? path('synapse_admin_workflows_new') : path('synapse_admin_workflows_edit', {id: workflow.id}) }}">

        <input type="hidden" name="_token" value="{{ csrf_token('synapse_workflow_edit') }}">

        {# ── Identité ──────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-card synapse-admin-mb-lg">
            <div class="synapse-admin-card__header">
                <div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="tag"></i>
                </div>
                <div>
                    <div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.identity.title'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.identity.subtitle'|trans(domain: 'synapse_admin') }}</div>
                </div>
            </div>
            <div class="synapse-admin-card__body synapse-admin-card__body--compact">

                <div class="synapse-admin-form-group synapse-admin-mb-md">
                    <label class="synapse-admin-label" for="workflow-key">
                        {{ 'synapse.admin.workflow.edit.label.key'|trans(domain: 'synapse_admin') }} <span class="synapse-admin-required">*</span>
                        {% if workflow.isBuiltin %}
                            <span class="synapse-admin-badge synapse-admin-badge--neutral synapse-admin-ml-sm" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.edit.tooltip.key_locked'|trans(domain: 'synapse_admin') }}">
                                <i data-lucide="lock"></i>
                                {{ 'synapse.admin.workflow.edit.badge.locked'|trans(domain: 'synapse_admin') }}
                            </span>
                        {% endif %}
                    </label>
                    <input type="text" id="workflow-key" name="workflow_key" value="{{ workflow.workflowKey }}"
                        class="synapse-admin-input synapse-admin-font-mono"
                        {{ workflow.isBuiltin ? 'readonly' : '' }}
                        required placeholder="ex: document_summary"
                        pattern="[a-z0-9_-]+" title="{{ 'synapse.admin.workflow.edit.pattern_title'|trans(domain: 'synapse_admin') }}">
                    {% if errors.workflow_key is defined %}
                        <p class="synapse-admin-form-error"><i data-lucide="alert-circle"></i> {{ errors.workflow_key }}</p>
                    {% endif %}
                    <p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.key'|trans(domain: 'synapse_admin') }}</p>
                </div>

                <div class="synapse-admin-form-group synapse-admin-mb-md">
                    <label class="synapse-admin-label" for="workflow-name">
                        {{ 'synapse.admin.workflow.edit.label.name'|trans(domain: 'synapse_admin') }} <span class="synapse-admin-required">*</span>
                    </label>
                    <input type="text" id="workflow-name" name="name" value="{{ workflow.name }}"
                        class="synapse-admin-input" required
                        placeholder="{{ 'synapse.admin.workflow.edit.placeholder.name'|trans(domain: 'synapse_admin') }}">
                    {% if errors.name is defined %}
                        <p class="synapse-admin-form-error"><i data-lucide="alert-circle"></i> {{ errors.name }}</p>
                    {% endif %}
                </div>

                <div class="synapse-admin-form-group synapse-admin-mb-md">
                    <label class="synapse-admin-label" for="workflow-description">
                        {{ 'synapse.admin.workflow.edit.label.description'|trans(domain: 'synapse_admin') }}
                    </label>
                    <textarea id="workflow-description" name="description" class="synapse-admin-input synapse-admin-textarea" rows="2"
                        placeholder="{{ 'synapse.admin.workflow.edit.placeholder.description'|trans(domain: 'synapse_admin') }}">{{ workflow.description }}</textarea>
                </div>

                <div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-lg">
                    <div class="synapse-admin-form-group">
                        <label class="synapse-admin-checkbox-label">
                            <input type="checkbox" name="is_active" {{ workflow.isActive ? 'checked' : '' }}>
                            <span>{{ 'synapse.admin.workflow.edit.label.active'|trans(domain: 'synapse_admin') }}</span>
                        </label>
                        <p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.active'|trans(domain: 'synapse_admin') }}</p>
                    </div>

                    <div class="synapse-admin-form-group">
                        <label class="synapse-admin-label" for="workflow-sort-order">
                            {{ 'synapse.admin.workflow.edit.label.sort_order'|trans(domain: 'synapse_admin') }}
                        </label>
                        <input type="number" id="workflow-sort-order" name="sort_order" value="{{ workflow.sortOrder }}"
                            class="synapse-admin-input" min="0" step="1">
                    </div>
                </div>

                {% if not is_new %}
                    <div class="synapse-admin-flex synapse-admin-gap-sm synapse-admin-mt-md">
                        <span class="synapse-admin-badge synapse-admin-badge--info">
                            <i data-lucide="git-commit"></i>
                            {{ 'synapse.admin.workflow.edit.label.version'|trans(domain: 'synapse_admin') }} v{{ workflow.version }}
                        </span>
                        {% if workflow.isBuiltin %}
                            <span class="synapse-admin-badge synapse-admin-badge--neutral">
                                <i data-lucide="lock"></i>
                                {{ 'synapse.admin.workflow.list.badge.builtin'|trans(domain: 'synapse_admin') }}
                            </span>
                        {% endif %}
                    </div>
                {% endif %}

            </div>
        </div>

        {# ── Pipeline (Visual Step Builder + JSON toggle) ─────────────────────── #}
        <input type="hidden" id="workflow-definition-json" name="definition"
            value="{{ workflow.definition|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES')) }}">

        <div class="synapse-admin-card synapse-admin-mb-lg">
            <div class="synapse-admin-card__header">
                <div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="workflow"></i>
                </div>
                <div>
                    <div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.definition.title'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.definition.subtitle'|trans(domain: 'synapse_admin') }}</div>
                </div>
                <div class="synapse-admin-card__header-actions">
                    <div class="synapse-step-builder-mode-toggle">
                        <button type="button" id="btn-mode-visual" class="synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--primary">
                            <i data-lucide="layout-list"></i> {{ 'synapse.admin.workflow.edit.builder.mode_visual'|trans(domain: 'synapse_admin') }}
                        </button>
                        <button type="button" id="btn-mode-json" class="synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--ghost">
                            <i data-lucide="code"></i> {{ 'synapse.admin.workflow.edit.builder.mode_json'|trans(domain: 'synapse_admin') }}
                        </button>
                    </div>
                </div>
            </div>
            <div class="synapse-admin-card__body synapse-admin-card__body--compact">

                {% if errors.definition is defined %}
                    <div class="synapse-admin-alert synapse-admin-alert--danger synapse-admin-mb-md">
                        <i data-lucide="alert-circle"></i>
                        <div>{{ errors.definition }}</div>
                    </div>
                {% endif %}

                {# ── Visual builder ── #}
                <div id="workflow-visual-builder">
                    <div id="workflow-steps-container" class="synapse-step-builder-list"></div>

                    <button type="button" id="btn-add-step" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-mt-md" style="width:100%;">
                        <i data-lucide="plus"></i> {{ 'synapse.admin.workflow.edit.builder.add_step'|trans(domain: 'synapse_admin') }}
                    </button>

                    {# ── Outputs ── #}
                    <div class="synapse-step-builder-outputs synapse-admin-mt-lg">
                        <div class="synapse-admin-flex synapse-admin-items-center synapse-admin-justify-between synapse-admin-mb-sm">
                            <span class="synapse-admin-label">{{ 'synapse.admin.workflow.edit.builder.outputs'|trans(domain: 'synapse_admin') }}</span>
                            <button type="button" id="btn-add-output" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                                <i data-lucide="plus"></i> {{ 'synapse.admin.workflow.edit.builder.output_add'|trans(domain: 'synapse_admin') }}
                            </button>
                        </div>
                        <div id="workflow-outputs-container"></div>
                    </div>
                </div>

                {# ── JSON editor (hidden by default) ── #}
                <div id="workflow-json-editor" hidden>
                    <textarea id="workflow-definition-textarea"
                        class="synapse-admin-input synapse-admin-textarea synapse-admin-font-mono"
                        rows="20" spellcheck="false"
                        style="font-size: 0.85rem; line-height: 1.5;"></textarea>
                    <p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.definition'|trans(domain: 'synapse_admin') }}</p>
                </div>

            </div>
        </div>

    </form>

    {# ── Exécutions récentes (read-only — moteur en Phase 8) ────────────────────── #}
    {% if not is_new %}
        <div class="synapse-admin-card synapse-admin-mb-lg">
            <div class="synapse-admin-card__header">
                <div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="activity"></i>
                </div>
                <div>
                    <div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.runs.title'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.runs.subtitle'|trans(domain: 'synapse_admin') }}</div>
                </div>
                <div style="margin-left: auto;">
                    <a href="{{ path('synapse_admin_workflows_runs', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                        <i data-lucide="external-link"></i>
                        {{ 'synapse.admin.workflow.edit.action.view_all_runs'|trans(domain: 'synapse_admin') }}
                    </a>
                </div>
            </div>
            <div class="synapse-admin-card__body synapse-admin-card__body--compact">

                {% if runs is empty %}
                    <div class="synapse-admin-empty-state synapse-admin-empty-state--inline">
                        <i data-lucide="info" class="synapse-admin-empty-state__icon"></i>
                        <p class="synapse-admin-empty-state__title">{{ 'synapse.admin.workflow.edit.runs.empty.title'|trans(domain: 'synapse_admin') }}</p>
                        <p class="synapse-admin-empty-state__subtitle">{{ 'synapse.admin.workflow.edit.runs.empty.subtitle'|trans(domain: 'synapse_admin') }}</p>
                    </div>
                {% else %}
                    <table class="synapse-admin-table">
                        <thead>
                            <tr>
                                <th>{{ 'synapse.admin.workflow.runs.column.run_id'|trans(domain: 'synapse_admin') }}</th>
                                <th>{{ 'synapse.admin.workflow.runs.column.status'|trans(domain: 'synapse_admin') }}</th>
                                <th>{{ 'synapse.admin.workflow.runs.column.version'|trans(domain: 'synapse_admin') }}</th>
                                <th>{{ 'synapse.admin.workflow.runs.column.steps'|trans(domain: 'synapse_admin') }}</th>
                                <th>{{ 'synapse.admin.workflow.runs.column.started_at'|trans(domain: 'synapse_admin') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for run in runs %}
                                <tr>
                                    <td><code class="synapse-admin-font-mono" style="font-size: 0.75rem;">{{ run.workflowRunId|slice(0, 8) }}…</code></td>
                                    <td>
                                        <span class="synapse-admin-badge synapse-admin-badge--{{ run.status.value == 'completed' ? 'success' : (run.status.value == 'failed' ? 'danger' : (run.status.value == 'running' ? 'info' : 'neutral')) }}">
                                            {{ ('synapse.admin.workflow.status.' ~ run.status.value)|trans(domain: 'synapse_admin') }}
                                        </span>
                                    </td>
                                    <td>v{{ run.workflowVersion }}</td>
                                    <td>{{ run.currentStepIndex }} / {{ run.stepsCount }}</td>
                                    <td>{{ run.startedAt ? run.startedAt|date('d/m/Y H:i:s') : '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}

            </div>
        </div>
    {% endif %}

    <script>
    (function () {
        'use strict';

        /* ── DOM refs ─────────────────────────────────────────────────────── */
        const hiddenInput    = document.getElementById('workflow-definition-json');
        const stepsContainer = document.getElementById('workflow-steps-container');
        const outsContainer  = document.getElementById('workflow-outputs-container');
        const visualPanel    = document.getElementById('workflow-visual-builder');
        const jsonPanel      = document.getElementById('workflow-json-editor');
        const jsonTextarea   = document.getElementById('workflow-definition-textarea');
        const btnVisual      = document.getElementById('btn-mode-visual');
        const btnJson        = document.getElementById('btn-mode-json');
        const btnAddStep     = document.getElementById('btn-add-step');
        const btnAddOutput   = document.getElementById('btn-add-output');

        /* ── Data ─────────────────────────────────────────────────────────── */
        const agents = [
            {% for a in agents %}
            { key: '{{ a.key|e('js') }}', name: '{{ a.name|e('js') }}', emoji: '{{ a.emoji|e('js') }}' }{{ not loop.last ? ',' : '' }}
            {% endfor %}
        ];

        let def; // the live definition object
        try { def = JSON.parse(hiddenInput.value); } catch (e) { def = { version: 1, steps: [] }; }
        if (!def.steps) { def.steps = []; }
        if (!def.outputs) { def.outputs = {}; }
        // Le message du chat est toujours disponible comme input implicite
        if (!def.inputs || Object.keys(def.inputs).length === 0) {
            def.inputs = { message: { type: 'string', required: true } };
        }

        /* ── Helpers ──────────────────────────────────────────────────────── */
        function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        function syncJson() {
            hiddenInput.value = JSON.stringify(def, null, 2);
        }

        function refreshIcons() {
            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
        }

        /** Build <option> list for source selects (mappings & outputs). */
        function sourceOptions(currentValue, maxStepIndex) {
            const sel = (v) => currentValue === v ? ' selected' : '';
            // A value is literal if it's defined (even empty) and not a JSONPath
            const isLiteral = currentValue !== undefined && currentValue !== null && !String(currentValue).startsWith('$');
            const noSelection = currentValue === undefined || currentValue === null;
            let html = '<option value=""' + (noSelection ? ' selected' : '') + '>-- S\u00e9lectionner --</option>';

            // ── Le message du chat (= $.inputs.message)
            const msgPath = '$.inputs.message';
            html += '<option value="' + esc(msgPath) + '"' + sel(msgPath) + '>Le message envoy\u00e9 dans le chat</option>';

            // ── Autres inputs custom (sauf "message" déjà listé)
            const inputs = def.inputs || {};
            for (const k of Object.keys(inputs)) {
                if (k === 'message') continue;
                const v = '$.inputs.' + k;
                html += '<option value="' + esc(v) + '"' + sel(v) + '>Input \u00ab ' + esc(k) + ' \u00bb</option>';
            }

            // ── Résultats des étapes précédentes
            for (let i = 0; i < maxStepIndex; i++) {
                const s = def.steps[i];
                if (!s || !s.name) continue;
                const prefix = '$.steps.' + s.name + '.output.';
                html += '<option value="' + esc(prefix + 'text') + '"' + sel(prefix + 'text') + '>R\u00e9ponse de l\u2019\u00e9tape \u00ab ' + esc(s.name) + ' \u00bb</option>';
                html += '<option value="' + esc(prefix + 'data') + '"' + sel(prefix + 'data') + '>Donn\u00e9es JSON de l\u2019\u00e9tape \u00ab ' + esc(s.name) + ' \u00bb</option>';
            }

            // ── Texte fixe (instruction statique)
            html += '<option value="__literal__"' + (isLiteral ? ' selected' : '') + '>Texte fixe (instruction toujours identique)</option>';

            // Fallback: unknown path already stored
            if (currentValue && currentValue.startsWith('$')) {
                const exists = html.includes('value="' + esc(currentValue) + '"');
                if (!exists) {
                    html += '<option value="' + esc(currentValue) + '" selected>' + esc(currentValue) + '</option>';
                }
            }

            return html;
        }

        /* ── Render steps ─────────────────────────────────────────────────── */
        function render() {
            stepsContainer.innerHTML = '';

            if (def.steps.length === 0) {
                stepsContainer.innerHTML = '<div class="synapse-admin-alert synapse-admin-alert--info"><i data-lucide="info"></i><div>{{ 'synapse.admin.workflow.edit.builder.empty'|trans(domain: 'synapse_admin')|e('js') }}</div></div>';
                renderOutputs();
                refreshIcons();
                syncJson();
                return;
            }

            for (let i = 0; i < def.steps.length; i++) {
                stepsContainer.appendChild(renderStep(i));
            }
            renderOutputs();
            refreshIcons();
            syncJson();
        }

        function renderStep(index) {
            const step = def.steps[index];
            const card = document.createElement('div');
            card.className = 'synapse-admin-card synapse-step-builder-card synapse-admin-mb-md';

            // ── Header
            const header = document.createElement('div');
            header.className = 'synapse-admin-card__header synapse-step-builder-card__header';
            header.innerHTML =
                '<span class="synapse-admin-badge synapse-admin-badge--primary synapse-step-builder-badge">' + (index + 1) + '</span>' +
                '<input type="text" class="synapse-admin-input synapse-step-builder-name-input" ' +
                    'value="' + esc(step.name || '') + '" placeholder="{{ 'synapse.admin.workflow.edit.builder.step_name_placeholder'|trans(domain: 'synapse_admin')|e('js') }}">' +
                '<div class="synapse-step-builder-card__actions">' +
                    (index > 0 ? '<button type="button" class="synapse-admin-btn synapse-admin-btn--icon synapse-admin-btn--ghost synapse-admin-btn--sm" data-action="move-up" title="{{ 'synapse.admin.workflow.edit.builder.move_up'|trans(domain: 'synapse_admin')|e('js') }}"><i data-lucide="chevron-up"></i></button>' : '') +
                    (index < def.steps.length - 1 ? '<button type="button" class="synapse-admin-btn synapse-admin-btn--icon synapse-admin-btn--ghost synapse-admin-btn--sm" data-action="move-down" title="{{ 'synapse.admin.workflow.edit.builder.move_down'|trans(domain: 'synapse_admin')|e('js') }}"><i data-lucide="chevron-down"></i></button>' : '') +
                    '<button type="button" class="synapse-admin-btn synapse-admin-btn--icon synapse-admin-btn--danger synapse-admin-btn--sm" data-action="remove" title="{{ 'synapse.admin.workflow.edit.builder.remove_step'|trans(domain: 'synapse_admin')|e('js') }}"><i data-lucide="trash-2"></i></button>' +
                '</div>';
            card.appendChild(header);

            // Name change
            header.querySelector('.synapse-step-builder-name-input').addEventListener('input', function () {
                step.name = this.value.replace(/[^a-zA-Z0-9_-]/g, '');
                this.value = step.name;
                syncJson();
            });

            // Header actions
            header.addEventListener('click', function (e) {
                const btn = e.target.closest('[data-action]');
                if (!btn) return;
                const action = btn.dataset.action;
                if (action === 'move-up') { moveStep(index, -1); }
                else if (action === 'move-down') { moveStep(index, 1); }
                else if (action === 'remove') { removeStep(index); }
            });

            // ── Body
            const body = document.createElement('div');
            body.className = 'synapse-admin-card__body synapse-admin-card__body--compact';

            // Agent select
            let agentHtml = '<div class="synapse-admin-form-group synapse-admin-mb-md">' +
                '<label class="synapse-admin-label">{{ 'synapse.admin.workflow.edit.builder.agent'|trans(domain: 'synapse_admin')|e('js') }} <span class="synapse-admin-required">*</span></label>' +
                '<select class="synapse-admin-input" data-field="agent_name">' +
                '<option value="">\u2014 {{ 'synapse.admin.workflow.edit.builder.agent_placeholder'|trans(domain: 'synapse_admin')|e('js') }} \u2014</option>';
            let agentFound = false;
            for (const a of agents) {
                const sel = step.agent_name === a.key ? ' selected' : '';
                if (sel) agentFound = true;
                agentHtml += '<option value="' + esc(a.key) + '"' + sel + '>' + esc(a.emoji) + ' ' + esc(a.name) + ' (' + esc(a.key) + ')</option>';
            }
            if (step.agent_name && !agentFound) {
                agentHtml += '<option value="' + esc(step.agent_name) + '" selected>\u26a0\ufe0f ' + esc(step.agent_name) + ' (introuvable)</option>';
            }
            agentHtml += '</select></div>';
            body.innerHTML = agentHtml;

            body.querySelector('[data-field="agent_name"]').addEventListener('change', function () {
                step.agent_name = this.value;
                syncJson();
            });

            // Mapping section
            const mappingSection = document.createElement('div');
            mappingSection.className = 'synapse-step-builder-mapping synapse-admin-mt-sm';

            const mappingHeader = document.createElement('div');
            mappingHeader.className = 'synapse-admin-flex synapse-admin-items-center synapse-admin-justify-between synapse-admin-mb-sm';
            mappingHeader.innerHTML =
                '<span class="synapse-admin-label synapse-admin-text-sm">{{ 'synapse.admin.workflow.edit.builder.mapping'|trans(domain: 'synapse_admin')|e('js') }}</span>' +
                '<button type="button" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm" data-action="add-mapping"><i data-lucide="plus"></i> {{ 'synapse.admin.workflow.edit.builder.mapping_add'|trans(domain: 'synapse_admin')|e('js') }}</button>';
            mappingSection.appendChild(mappingHeader);

            mappingHeader.querySelector('[data-action="add-mapping"]').addEventListener('click', function () {
                if (!step.input_mapping) step.input_mapping = {};
                step.input_mapping['param_' + Date.now()] = '';
                syncJson();
                render();
            });

            const mappingRows = document.createElement('div');
            mappingRows.className = 'synapse-step-builder-mapping-rows';
            const mapping = step.input_mapping || {};
            const keys = Object.keys(mapping);
            if (keys.length === 0) {
                mappingRows.innerHTML = '<div class="synapse-admin-text-xs synapse-admin-text-tertiary" style="padding:0.25rem 0;">Aucun mapping.</div>';
            } else {
                for (const k of keys) {
                    mappingRows.appendChild(renderMappingRow(step, k, index));
                }
            }
            mappingSection.appendChild(mappingRows);
            body.appendChild(mappingSection);

            card.appendChild(body);
            return card;
        }

        function isLiteralValue(v) {
            return v !== undefined && v !== null && !String(v).startsWith('$');
        }

        function renderMappingRow(step, key, stepIndex) {
            const row = document.createElement('div');
            row.className = 'synapse-step-builder-mapping-row';

            const value = step.input_mapping[key];
            const literal = isLiteralValue(value);

            // Build base row: key input + source select + remove button
            row.innerHTML =
                '<input type="text" class="synapse-admin-input synapse-step-builder-mapping-key" value="' + esc(key) + '" placeholder="{{ 'synapse.admin.workflow.edit.builder.mapping_key'|trans(domain: 'synapse_admin')|e('js') }}">' +
                '<select class="synapse-admin-input synapse-step-builder-mapping-source">' + sourceOptions(value, stepIndex) + '</select>' +
                '<button type="button" class="synapse-admin-btn synapse-admin-btn--icon synapse-admin-btn--ghost synapse-admin-btn--sm" data-action="remove-mapping"><i data-lucide="x"></i></button>';

            const selectEl = row.querySelector('.synapse-step-builder-mapping-source');
            const removeBtn = row.querySelector('[data-action="remove-mapping"]');

            // Insert literal text input if needed (before the remove button)
            function showLiteralInput() {
                let litInput = row.querySelector('.synapse-step-builder-mapping-literal');
                if (litInput) return litInput;
                litInput = document.createElement('input');
                litInput.type = 'text';
                litInput.className = 'synapse-admin-input synapse-step-builder-mapping-literal';
                litInput.placeholder = '{{ 'synapse.admin.workflow.edit.builder.mapping_literal'|trans(domain: 'synapse_admin')|e('js') }}';
                litInput.value = isLiteralValue(step.input_mapping[key]) ? step.input_mapping[key] : '';
                litInput.addEventListener('input', function () {
                    step.input_mapping[key] = this.value;
                    syncJson();
                });
                row.insertBefore(litInput, removeBtn);
                return litInput;
            }

            function hideLiteralInput() {
                const litInput = row.querySelector('.synapse-step-builder-mapping-literal');
                if (litInput) litInput.remove();
            }

            // Show literal input on initial render if value is literal
            if (literal) { showLiteralInput(); }

            // Key change
            row.querySelector('.synapse-step-builder-mapping-key').addEventListener('input', function () {
                const oldKey = key;
                const newKey = this.value.replace(/[^a-zA-Z0-9_-]/g, '');
                this.value = newKey;
                if (newKey !== oldKey && newKey) {
                    const val = step.input_mapping[oldKey];
                    delete step.input_mapping[oldKey];
                    step.input_mapping[newKey] = val;
                    key = newKey;
                    syncJson();
                }
            });

            // Source select change — no re-render, toggle literal input inline
            selectEl.addEventListener('change', function () {
                if (this.value === '__literal__') {
                    step.input_mapping[key] = '';
                    const litInput = showLiteralInput();
                    litInput.focus();
                    syncJson();
                } else {
                    step.input_mapping[key] = this.value;
                    hideLiteralInput();
                    syncJson();
                }
            });

            // Remove
            removeBtn.addEventListener('click', function () {
                delete step.input_mapping[key];
                syncJson();
                render();
            });

            return row;
        }

        /* ── Render outputs ───────────────────────────────────────────────── */
        function renderOutputs() {
            outsContainer.innerHTML = '';
            const outputs = def.outputs || {};
            const keys = Object.keys(outputs);

            if (keys.length === 0) {
                outsContainer.innerHTML = '<div class="synapse-admin-text-xs synapse-admin-text-tertiary" style="padding:0.25rem 0;">Aucune sortie d\u00e9finie.</div>';
                return;
            }

            for (const k of keys) {
                outsContainer.appendChild(renderOutputRow(k));
            }
        }

        function renderOutputRow(key) {
            const row = document.createElement('div');
            row.className = 'synapse-step-builder-mapping-row';

            const value = def.outputs[key] || '';
            row.innerHTML =
                '<input type="text" class="synapse-admin-input synapse-step-builder-mapping-key" value="' + esc(key) + '" placeholder="{{ 'synapse.admin.workflow.edit.builder.output_key'|trans(domain: 'synapse_admin')|e('js') }}">' +
                '<select class="synapse-admin-input synapse-step-builder-mapping-source">' + sourceOptions(value, def.steps.length) + '</select>' +
                '<button type="button" class="synapse-admin-btn synapse-admin-btn--icon synapse-admin-btn--ghost synapse-admin-btn--sm" data-action="remove-output"><i data-lucide="x"></i></button>';

            // Key change
            row.querySelector('.synapse-step-builder-mapping-key').addEventListener('input', function () {
                const oldKey = key;
                const newKey = this.value.replace(/[^a-zA-Z0-9_-]/g, '');
                this.value = newKey;
                if (newKey !== oldKey && newKey) {
                    const val = def.outputs[oldKey];
                    delete def.outputs[oldKey];
                    def.outputs[newKey] = val;
                    key = newKey;
                    syncJson();
                }
            });

            // Source select
            row.querySelector('.synapse-step-builder-mapping-source').addEventListener('change', function () {
                def.outputs[key] = this.value;
                syncJson();
            });

            // Remove
            row.querySelector('[data-action="remove-output"]').addEventListener('click', function () {
                delete def.outputs[key];
                syncJson();
                render();
            });

            return row;
        }

        /* ── Step actions ─────────────────────────────────────────────────── */
        function addStep() {
            def.steps.push({ name: 'step_' + (def.steps.length + 1), agent_name: '', input_mapping: {} });
            syncJson();
            render();
        }

        function removeStep(index) {
            def.steps.splice(index, 1);
            syncJson();
            render();
        }

        function moveStep(index, direction) {
            const target = index + direction;
            if (target < 0 || target >= def.steps.length) return;
            const tmp = def.steps[index];
            def.steps[index] = def.steps[target];
            def.steps[target] = tmp;
            syncJson();
            render();
        }

        /* ── Mode toggle ──────────────────────────────────────────────────── */
        function setMode(mode) {
            if (mode === 'json') {
                syncJson();
                jsonTextarea.value = JSON.stringify(def, null, 2);
                visualPanel.hidden = true;
                jsonPanel.hidden = false;
                btnJson.className = 'synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--primary';
                btnVisual.className = 'synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--ghost';
            } else {
                // Parse textarea back into def
                try {
                    const parsed = JSON.parse(jsonTextarea.value);
                    // Preserve unknown fields
                    Object.assign(def, parsed);
                    def.steps = parsed.steps || [];
                    def.outputs = parsed.outputs || {};
                } catch (e) {
                    // If JSON is invalid, stay in JSON mode
                    alert('JSON invalide : ' + e.message);
                    return;
                }
                visualPanel.hidden = false;
                jsonPanel.hidden = true;
                btnVisual.className = 'synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--primary';
                btnJson.className = 'synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--ghost';
                render();
            }
        }

        /* ── Event bindings ───────────────────────────────────────────────── */
        btnAddStep.addEventListener('click', addStep);
        btnAddOutput.addEventListener('click', function () {
            if (!def.outputs) def.outputs = {};
            def.outputs['output_' + (Object.keys(def.outputs).length + 1)] = '';
            syncJson();
            render();
        });
        btnVisual.addEventListener('click', function () { setMode('visual'); });
        btnJson.addEventListener('click', function () { setMode('json'); });

        /* ── Initial render ───────────────────────────────────────────────── */
        render();
    })();
    </script>

{% endblock %}
