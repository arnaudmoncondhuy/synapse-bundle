{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}
	{{ is_new ? 'synapse.admin.workflow.edit.page_title.new'|trans(domain='synapse_admin') : 'synapse.admin.workflow.edit.page_title.edit'|trans({'name': workflow.name}, domain='synapse_admin') }}
{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_workflows') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.workflows'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-current">{{ is_new ? 'synapse.admin.common.new'|trans(domain='synapse_admin') : workflow.name }}</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="workflow"></i>
				</span>
				{{ is_new
					? 'synapse.admin.workflow.edit.title.new'|trans(domain='synapse_admin')
					: 'synapse.admin.workflow.edit.title.edit'|trans({'name': workflow.name}, domain='synapse_admin') }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ is_new
					? 'synapse.admin.workflow.edit.subtitle.new'|trans(domain='synapse_admin')
					: 'synapse.admin.workflow.edit.subtitle.edit'|trans(domain='synapse_admin') }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_workflows') }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
				<i data-lucide="x"></i>
				{{ 'synapse.admin.common.cancel'|trans(domain='synapse_admin') }}
			</a>
			<button type="submit" form="workflow-form" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
				<i data-lucide="save"></i>
				{{ is_new ? 'synapse.admin.workflow.edit.action.create'|trans(domain='synapse_admin') : 'synapse.admin.workflow.edit.action.save'|trans(domain='synapse_admin') }}
			</button>
		</div>
	</div>

	<form id="workflow-form" method="post" action="{{ is_new ? path('synapse_admin_workflows_new') : path('synapse_admin_workflows_edit', {id: workflow.id}) }}">

		<input type="hidden" name="_token" value="{{ csrf_token('synapse_workflow_edit') }}">

		{# ── Identité ──────────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="tag"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.identity.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.identity.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				<div class="synapse-admin-form-group synapse-admin-mb-md">
					<label class="synapse-admin-label" for="workflow-key">
						{{ 'synapse.admin.workflow.edit.label.key'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span>
						{% if workflow.isBuiltin %}
							<span class="synapse-admin-badge synapse-admin-badge--neutral synapse-admin-ml-sm" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.edit.tooltip.key_locked'|trans(domain='synapse_admin') }}">
								<i data-lucide="lock"></i>
								{{ 'synapse.admin.workflow.edit.badge.locked'|trans(domain='synapse_admin') }}
							</span>
						{% endif %}
					</label>
					<input type="text" id="workflow-key" name="workflow_key" value="{{ workflow.workflowKey }}"
						class="synapse-admin-input synapse-admin-font-mono"
						{{ workflow.isBuiltin ? 'readonly' : '' }}
						required placeholder="ex: document_summary"
						pattern="[a-z0-9_-]+" title="{{ 'synapse.admin.workflow.edit.pattern_title'|trans(domain='synapse_admin') }}">
					{% if errors.workflow_key is defined %}
						<p class="synapse-admin-form-error"><i data-lucide="alert-circle"></i> {{ errors.workflow_key }}</p>
					{% endif %}
					<p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.key'|trans(domain='synapse_admin') }}</p>
				</div>

				<div class="synapse-admin-form-group synapse-admin-mb-md">
					<label class="synapse-admin-label" for="workflow-name">
						{{ 'synapse.admin.workflow.edit.label.name'|trans(domain='synapse_admin') }} <span class="synapse-admin-required">*</span>
					</label>
					<input type="text" id="workflow-name" name="name" value="{{ workflow.name }}"
						class="synapse-admin-input" required
						placeholder="{{ 'synapse.admin.workflow.edit.placeholder.name'|trans(domain='synapse_admin') }}">
					{% if errors.name is defined %}
						<p class="synapse-admin-form-error"><i data-lucide="alert-circle"></i> {{ errors.name }}</p>
					{% endif %}
				</div>

				<div class="synapse-admin-form-group synapse-admin-mb-md">
					<label class="synapse-admin-label" for="workflow-description">
						{{ 'synapse.admin.workflow.edit.label.description'|trans(domain='synapse_admin') }}
					</label>
					<textarea id="workflow-description" name="description" class="synapse-admin-input synapse-admin-textarea" rows="2"
						placeholder="{{ 'synapse.admin.workflow.edit.placeholder.description'|trans(domain='synapse_admin') }}">{{ workflow.description }}</textarea>
				</div>

				<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-lg">
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-checkbox-label">
							<input type="checkbox" name="is_active" {{ workflow.isActive ? 'checked' : '' }}>
							<span>{{ 'synapse.admin.workflow.edit.label.active'|trans(domain='synapse_admin') }}</span>
						</label>
						<p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.active'|trans(domain='synapse_admin') }}</p>
					</div>

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="workflow-sort-order">
							{{ 'synapse.admin.workflow.edit.label.sort_order'|trans(domain='synapse_admin') }}
						</label>
						<input type="number" id="workflow-sort-order" name="sort_order" value="{{ workflow.sortOrder }}"
							class="synapse-admin-input" min="0" step="1">
					</div>
				</div>

				{% if not is_new %}
					<div class="synapse-admin-flex synapse-admin-gap-sm synapse-admin-mt-md">
						<span class="synapse-admin-badge synapse-admin-badge--info">
							<i data-lucide="git-commit"></i>
							{{ 'synapse.admin.workflow.edit.label.version'|trans(domain='synapse_admin') }} v{{ workflow.version }}
						</span>
						{% if workflow.isBuiltin %}
							<span class="synapse-admin-badge synapse-admin-badge--neutral">
								<i data-lucide="lock"></i>
								{{ 'synapse.admin.workflow.list.badge.builtin'|trans(domain='synapse_admin') }}
							</span>
						{% endif %}
					</div>
				{% endif %}

			</div>
		</div>

		{# ── Pipeline (Visual Step Builder + JSON toggle) ─────────────────────── #}
		{# Chantier J : builder Stimulus. L'input hidden contient la definition JSON, #}
		{# le controller `synapse-workflow-builder` lit/écrit via le target               #}
		{# `definitionInput` et re-render le visual panel.                                 #}

		<div class="synapse-admin-card synapse-admin-mb-lg"
			data-controller="synapse-workflow-builder"
			data-synapse-workflow-builder-agents-value="{{ agents_json|default('[]') }}"
			data-synapse-workflow-builder-workflows-value="{{ workflows_json|default('[]') }}"
		>
			<input type="hidden" name="definition"
				data-synapse-workflow-builder-target="definitionInput"
				value="{{ workflow.definition|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES')) }}">

			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="workflow"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.definition.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.definition.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
				<div class="synapse-admin-card__header-actions">
					<div class="synapse-step-builder-mode-toggle">
						<button type="button"
							class="synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--primary"
							data-synapse-workflow-builder-target="modeVisualButton"
							data-action="synapse-workflow-builder#setModeVisual">
							<i data-lucide="layout-list"></i> {{ 'synapse.admin.workflow.edit.builder.mode_visual'|trans(domain='synapse_admin') }}
						</button>
						<button type="button"
							class="synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--ghost"
							data-synapse-workflow-builder-target="modeJsonButton"
							data-action="synapse-workflow-builder#setModeJson">
							<i data-lucide="code"></i> {{ 'synapse.admin.workflow.edit.builder.mode_json'|trans(domain='synapse_admin') }}
						</button>
					</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				{% if errors.definition is defined %}
					<div class="synapse-admin-alert synapse-admin-alert--danger synapse-admin-mb-md">
						<i data-lucide="alert-circle"></i>
						<div>{{ errors.definition }}</div>
					</div>
				{% endif %}

				{# ── Visual builder ── #}
				<div data-synapse-workflow-builder-target="visualPanel">
					<div data-synapse-workflow-builder-target="stepsContainer" class="synapse-step-builder-list"></div>

					<button type="button"
						class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-mt-md"
						style="width:100%;"
						data-synapse-workflow-builder-target="addStepButton"
						data-action="synapse-workflow-builder#addStep">
						<i data-lucide="plus"></i> {{ 'synapse.admin.workflow.edit.builder.add_step'|trans(domain='synapse_admin') }}
					</button>

					{# ── Outputs ── #}
					<div class="synapse-step-builder-outputs synapse-admin-mt-lg">
						<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-justify-between synapse-admin-mb-sm">
							<span class="synapse-admin-label">{{ 'synapse.admin.workflow.edit.builder.outputs'|trans(domain='synapse_admin') }}</span>
							<button type="button"
								class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm"
								data-synapse-workflow-builder-target="addOutputButton"
								data-action="synapse-workflow-builder#addOutput">
								<i data-lucide="plus"></i> {{ 'synapse.admin.workflow.edit.builder.output_add'|trans(domain='synapse_admin') }}
							</button>
						</div>
						<div data-synapse-workflow-builder-target="outputsContainer"></div>
					</div>
				</div>

				{# ── JSON editor (hidden by default) ── #}
				<div data-synapse-workflow-builder-target="jsonPanel" hidden>
					<textarea
						data-synapse-workflow-builder-target="jsonTextarea"
						class="synapse-admin-input synapse-admin-textarea synapse-admin-font-mono"
						rows="20" spellcheck="false"
						style="font-size: 0.85rem; line-height: 1.5;"></textarea>
					<p class="synapse-admin-help-text">{{ 'synapse.admin.workflow.edit.help.definition'|trans(domain='synapse_admin') }}</p>
				</div>

			</div>
		</div>

	</form>

	{# ── Exécutions récentes (read-only — moteur en Phase 8) ────────────────────── #}
	{% if not is_new %}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="activity"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.edit.section.runs.title'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.edit.section.runs.subtitle'|trans(domain='synapse_admin') }}</div>
				</div>
				<div style="margin-left: auto;">
					<a href="{{ path('synapse_admin_workflows_runs', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
						<i data-lucide="external-link"></i>
						{{ 'synapse.admin.workflow.edit.action.view_all_runs'|trans(domain='synapse_admin') }}
					</a>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">

				{% if runs is empty %}
					<div class="synapse-admin-empty-state synapse-admin-empty-state--inline">
						<i data-lucide="info" class="synapse-admin-empty-state__icon"></i>
						<p class="synapse-admin-empty-state__title">{{ 'synapse.admin.workflow.edit.runs.empty.title'|trans(domain='synapse_admin') }}</p>
						<p class="synapse-admin-empty-state__subtitle">{{ 'synapse.admin.workflow.edit.runs.empty.subtitle'|trans(domain='synapse_admin') }}</p>
					</div>
				{% else %}
					<table class="synapse-admin-table">
						<thead>
							<tr>
								<th>{{ 'synapse.admin.workflow.runs.column.run_id'|trans(domain='synapse_admin') }}</th>
								<th>{{ 'synapse.admin.workflow.runs.column.status'|trans(domain='synapse_admin') }}</th>
								<th>{{ 'synapse.admin.workflow.runs.column.version'|trans(domain='synapse_admin') }}</th>
								<th>{{ 'synapse.admin.workflow.runs.column.steps'|trans(domain='synapse_admin') }}</th>
								<th>{{ 'synapse.admin.workflow.runs.column.started_at'|trans(domain='synapse_admin') }}</th>
							</tr>
						</thead>
						<tbody>
							{% for run in runs %}
								<tr>
									<td><code class="synapse-admin-font-mono" style="font-size: 0.75rem;">{{ run.workflowRunId|slice(0, 8) }}…</code></td>
									<td>
										<span class="synapse-admin-badge synapse-admin-badge--{{ run.status.value == 'completed' ? 'success' : (run.status.value == 'failed' ? 'danger' : (run.status.value == 'running' ? 'info' : 'neutral')) }}">
											{{ ('synapse.admin.workflow.status.' ~ run.status.value)|trans(domain='synapse_admin') }}
										</span>
									</td>
									<td>v{{ run.workflowVersion }}</td>
									<td>{{ run.currentStepIndex }} / {{ run.stepsCount }}</td>
									<td>{{ run.startedAt ? run.startedAt|date('d/m/Y H:i:s') : '—' }}</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				{% endif %}

			</div>
		</div>
	{% endif %}


{% endblock %}
