{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.workflow.runs.page_title'|trans({name: workflow.name}, domain: 'synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="{{ path('synapse_admin_workflows') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.workflows'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="{{ path('synapse_admin_workflows_edit', {id: workflow.id}) }}" class="synapse-admin-topbar__breadcrumb">{{ workflow.name }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <span class="synapse-admin-current">{{ 'synapse.admin.workflow.runs.breadcrumb'|trans(domain: 'synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

    <div class="synapse-admin-page-header">
        <div class="synapse-admin-page-header__info">
            <h1 class="synapse-admin-page-title">
                <span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="activity"></i>
                </span>
                {{ 'synapse.admin.workflow.runs.title'|trans({name: workflow.name}, domain: 'synapse_admin') }}
            </h1>
            <p class="synapse-admin-page-subtitle">
                {{ 'synapse.admin.workflow.runs.subtitle'|trans(domain: 'synapse_admin') }}
            </p>
        </div>
        <div class="synapse-admin-page-header__actions">
            <a href="{{ path('synapse_admin_workflows_edit', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                <i data-lucide="arrow-left"></i>
                {{ 'synapse.admin.workflow.runs.action.back'|trans(domain: 'synapse_admin') }}
            </a>
        </div>
    </div>

    {# ── Statistiques ──────────────────────────────────────────────────────── #}
    <div class="synapse-admin-grid synapse-admin-grid--5 synapse-admin-mb-lg">
        {% for status in ['pending', 'running', 'completed', 'failed', 'cancelled'] %}
            <div class="synapse-admin-kpi-card">
                <div class="synapse-admin-kpi__label">{{ ('synapse.admin.workflow.status.' ~ status)|trans(domain: 'synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">{{ counts[status] ?? 0 }}</div>
            </div>
        {% endfor %}
    </div>

    {# ── Tableau des runs ──────────────────────────────────────────────────── #}
    <div class="synapse-admin-card">
        <div class="synapse-admin-card__header">
            <div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
                <i data-lucide="list"></i>
            </div>
            <div>
                <div class="synapse-admin-card__title">{{ 'synapse.admin.workflow.runs.table.title'|trans(domain: 'synapse_admin') }}</div>
                <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.workflow.runs.table.subtitle'|trans({count: runs|length}, domain: 'synapse_admin') }}</div>
            </div>
        </div>
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">

            {% if runs is empty %}
                <div class="synapse-admin-empty-state">
                    <i data-lucide="activity" class="synapse-admin-empty-state__icon"></i>
                    <p class="synapse-admin-empty-state__title">{{ 'synapse.admin.workflow.runs.empty.title'|trans(domain: 'synapse_admin') }}</p>
                    <p class="synapse-admin-empty-state__subtitle">{{ 'synapse.admin.workflow.runs.empty.subtitle'|trans(domain: 'synapse_admin') }}</p>
                </div>
            {% else %}
                <table class="synapse-admin-table">
                    <thead>
                        <tr>
                            <th>{{ 'synapse.admin.workflow.runs.column.run_id'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.status'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.version'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.steps'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.duration'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.tokens'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.started_at'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.workflow.runs.column.actions'|trans(domain: 'synapse_admin') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for run in runs %}
                            {% set status = run.status is defined ? run.status : run['status'] %}
                            {% set statusValue = status.value is defined ? status.value : status %}
                            <tr>
                                <td>
                                    <code class="synapse-admin-font-mono" style="font-size: 0.75rem;" data-synapse-admin-tooltip="{{ run.workflowRunId }}">
                                        {{ run.workflowRunId|slice(0, 8) }}…
                                    </code>
                                </td>
                                <td>
                                    <span class="synapse-admin-badge synapse-admin-badge--{{ statusValue == 'completed' ? 'success' : (statusValue == 'failed' ? 'danger' : (statusValue == 'running' ? 'info' : 'neutral')) }}">
                                        {{ ('synapse.admin.workflow.status.' ~ statusValue)|trans(domain: 'synapse_admin') }}
                                    </span>
                                </td>
                                <td>v{{ run.workflowVersion }}</td>
                                <td>{{ run.currentStepIndex }} / {{ run.stepsCount }}</td>
                                <td>
                                    {% if run.completedAt and run.startedAt %}
                                        {{ (run.completedAt.timestamp - run.startedAt.timestamp) }}s
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ run.totalTokens ?? '—' }}</td>
                                <td>{{ run.startedAt ? run.startedAt|date('d/m/Y H:i:s') : '—' }}</td>
                                <td>
                                    <a href="{{ path('synapse_admin_systeme_debug') }}?workflow_run_id={{ run.workflowRunId }}"
                                       class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm"
                                       data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.runs.action.view_logs'|trans(domain: 'synapse_admin') }}">
                                        <i data-lucide="file-search"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}

        </div>
    </div>

{% endblock %}
