{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}
	{{ is_new ? 'Nouveau Model Preset' : 'Éditer : ' ~ preset.name }}
	| Intelligence | Synapse Administration Synapse
{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_configuration_llm') }}" class="synapse-admin-topbar__breadcrumb">Intelligence</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-topbar__breadcrumb">Model Presets</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">{{ is_new ? 'Nouveau' : preset.name }}</span>
{% endblock %}

{% block admin_content %}

	{# ── En-tête ──────────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="sliders-horizontal"></i>
				</span>
				{{ is_new ? 'Nouveau Model Preset LLM' : 'Éditer : ' ~ preset.name }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ is_new
                ? 'Configurez un nouveau profil de génération (provider, modèle, paramètres).'
                : 'Modifiez ce profil de génération LLM. Les changements sont appliqués immédiatement après sauvegarde.'
            }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			{% if not is_new %}
				<form method="post" action="{{ path('synapse_admin_presets_test', {id: preset.id}) }}" style="display:inline">
					<button type="submit" class="synapse-admin-btn synapse-admin-btn--outline synapse-admin-btn--sm">
						<i data-lucide="flask-conical"></i>
						Tester ce Model Preset
					</button>
				</form>
			{% endif %}
			<a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
				<i data-lucide="x"></i>
				Annuler
			</a>
			<button type="submit" form="preset-form" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
				<i data-lucide="save"></i>
				{{ is_new ? 'Créer le Model Preset' : 'Enregistrer les modifications' }}
			</button>
		</div>
	</div>

	{# ── Formulaire ───────────────────────────────────────────────────────────── #}
	<form method="post" id="preset-form" action="{{ is_new ? path('synapse_admin_presets_new') : path('synapse_admin_presets_edit', {id: preset.id}) }}" onsubmit="syncProviderOptionsBeforeSubmit()">

		<input
		type="hidden" name="_token" value="{{ csrf_token('synapse_preset_edit') }}">

		{# ── Nom du preset ──────────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="tag"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Identification</div>
					<div class="synapse-admin-card__subtitle">Nom et clé technique du Model Preset</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-grid synapse-admin-grid--2">
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="preset-name">
							Nom du Model Preset
							<span class="synapse-admin-required">*</span>
						</label>
						<input type="text" id="preset-name" name="name" value="{{ preset.name }}" class="synapse-admin-input" required placeholder="Ex: Mon Preset Créatif">
					</div>
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="preset-key">
							Clé technique (slug)
							<span class="synapse-admin-required">*</span>
						</label>
						<input type="text" id="preset-key" name="key" value="{{ preset.key }}" class="synapse-admin-input synapse-admin-font-mono"
							required placeholder="ex: mon_preset_creatif"
							pattern="[a-z0-9_]+" title="Lettres minuscules, chiffres et tirets bas uniquement">
						<p class="synapse-admin-help-text">Utilisée dans ChatService::ask(['model_preset' => '{{ preset.key ?: 'mon_preset' }}'])</p>
					</div>
				</div>
			</div>
		</div>

		{# ── Provider & Modèle ──────────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
					<i data-lucide="plug"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Provider & Modèle</div>
					<div class="synapse-admin-card__subtitle">Source et modèle de génération</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-grid" style="grid-template-columns: 1fr 1fr 1fr;">
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="provider-select">
							Provider
							<span class="synapse-admin-required">*</span>
						</label>
						<select name="provider_name" id="provider-select" class="synapse-admin-select" onchange="updateModelOptions(this.value); renderDynamicFields(this.value)">
							{% for provider in providers %}
								<option value="{{ provider.name }}" {% if provider.name == preset.providerName %} selected {% endif %}>
									{{ provider.label }}
									{% if not provider.isEnabled %}(désactivé)
									{% endif %}
								</option>
							{% endfor %}
						</select>
					</div>
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label" for="model-select">
							Modèle
							<span class="synapse-admin-required">*</span>
						</label>
						<select name="model" id="model-select" class="synapse-admin-select" onchange="updateFormVisibility(); updateModelPricing()">
							{% for provider, models in models_by_provider %}
								<optgroup label="{{ provider }}" data-provider="{{ provider }}">
									{% for modelId in models %}
										<option value="{{ modelId }}" data-provider="{{ provider }}" {% if modelId == preset.model %} selected {% endif %}>
											{{ modelId }}
										</option>
									{% endfor %}
								</optgroup>
							{% endfor %}
						</select>
					</div>
					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label">Tarif</label>
						<div id="model-pricing" class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-xs" style="padding-top: 0.45rem;"></div>
					</div>
				</div>
			</div>
		</div>

		{# ── Capacités du modèle (JS) ────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg" id="model-caps-display">
			<div
				class="synapse-admin-card__body synapse-admin-card__body--compact synapse-admin-flex synapse-admin-gap-sm synapse-admin-flex-wrap">{# Rempli par JS dynamiquement #}
			</div>
		</div>

		{# ── Paramètres de génération ─────────────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg" id="generation-params-card">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--neutral">
					<i data-lucide="settings-2"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Paramètres de génération</div>
					<div class="synapse-admin-card__subtitle">Contrôle de la créativité et des limites de sortie</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-grid synapse-admin-grid--3">

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label">Température</label>
						<div class="synapse-admin-range-wrapper">
							<input type="range" name="generation_temperature" min="0" max="2" step="0.1" value="{{ preset.generationTemperature }}" class="synapse-admin-range" oninput="this.nextElementSibling.textContent = this.value">
							<span class="synapse-admin-range-value">{{ preset.generationTemperature }}</span>
						</div>
						<p class="synapse-admin-help">0 = déterministe · 2 = très créatif</p>
					</div>

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label">Top P</label>
						<div class="synapse-admin-range-wrapper">
							<input type="range" name="generation_top_p" min="0" max="1" step="0.05" value="{{ preset.generationTopP }}" class="synapse-admin-range" oninput="this.nextElementSibling.textContent = this.value">
							<span class="synapse-admin-range-value">{{ preset.generationTopP }}</span>
						</div>
					</div>

					<div class="synapse-admin-form-group" id="section-top-k">
						<label class="synapse-admin-label">Top K</label>
						<input type="number" name="generation_top_k" value="{{ preset.generationTopK }}" min="1" max="100" class="synapse-admin-input">
						<p class="synapse-admin-help">Paramètre de filtrage pour certains modèles.</p>
					</div>

					<div class="synapse-admin-form-group">
						<label class="synapse-admin-label">Max Output Tokens</label>
						<input type="number" name="generation_max_output_tokens" value="{{ preset.generationMaxOutputTokens ?: '' }}" class="synapse-admin-input" placeholder="Illimité">
					</div>

					<div class="synapse-admin-form-group synapse-admin-col-span-2">
						<label class="synapse-admin-label">Séquences d'arrêt</label>
						<input type="text" name="generation_stop_sequences" value="{{ preset.generationStopSequences ? preset.generationStopSequences|join(', ') : '' }}" class="synapse-admin-input" placeholder="Ex: \\n, END, STOP (séparés par des virgules)">
					</div>

				</div>
			</div>
		</div>

		{# streaming_enabled toujours true — la pilule Streaming dans disabled_capabilities contrôle le comportement #}
		<input type="hidden" name="streaming_enabled" value="1">

	{# ── Options Provider (champs dynamiques JS) ─────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-lg" id="provider-options-card">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--warning">
					<i data-lucide="sliders-horizontal"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">Options du provider</div>
					<div class="synapse-admin-card__subtitle">Configuration dynamique (thinking, safety, etc.)</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div
					id="dynamic-provider-ui" class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-gap-lg">{# Champs injectés par JS #}
				</div>
			</div>
		</div>

		{# ── JSON Avancé (source de vérité) ──────────────────────────────────────── #}
		<div class="synapse-admin-card synapse-admin-mb-xl" id="provider-options-json-card">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--neutral">
					<i data-lucide="code-2"></i>
				</div>
				<div>
					<div class="synapse-admin-card__title">JSON avancé</div>
					<div class="synapse-admin-card__subtitle">Source de vérité synchronisée avec les champs ci-dessus</div>
				</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				<div class="synapse-admin-form-group">
					<label class="synapse-admin-label" for="provider-options-json">providerOptions (JSON)</label>
					<textarea id="provider-options-json" name="provider_options_json" class="synapse-admin-input synapse-admin-font-mono" rows="12" style="font-size: 12px; min-height: 200px;">{{ preset.providerOptions ? preset.providerOptions|json_encode(constant('JSON_PRETTY_PRINT')) : '{}' }}</textarea>
					<p class="synapse-admin-help synapse-admin-mt-sm">
						💡 Édition directe du JSON. Les changements aux champs dynamiques mettent à jour ce champ automatiquement.
					</p>
					<p class="synapse-admin-help synapse-admin-mt-xs synapse-admin-text-warning">
						⚠️ Syntaxe JSON invalide = sauvegarde refusée.
					</p>
				</div>
				<input type="hidden" name="provider_options" id="provider-options-hidden" value="{{ preset.providerOptions ? preset.providerOptions|json_encode : '{}' }}">
			</div>
		</div>

	</form>

	{# ── JS identique au V1 — Provider options dynamiques ───────────────────── #}
	<script>
		const modelCapabilities = {{ model_capabilities|json_encode|raw }};

const PROVIDER_SCHEMAS = {{ provider_schemas|json_encode|raw }};
const providerMeta = {{ provider_meta|json_encode|raw }};

function renderDynamicFields(providerName) {
const container = document.getElementById('dynamic-provider-ui');
if (! container) 
return;

container.innerHTML = '';
const modelId = document.getElementById('model-select').value;
const caps = modelCapabilities[modelId] || {};
let schema = PROVIDER_SCHEMAS[providerName];
const card = document.getElementById('provider-options-card');
const jsonCard = document.getElementById('provider-options-json-card');
if (! schema || ! schema.fields) {
if (card) 
card.style.display = 'none';

if (jsonCard) 
jsonCard.style.display = 'none';

return;
}
const jsonTextarea = document.getElementById('provider-options-json');
let currentData = {};
try {
currentData = JSON.parse(jsonTextarea.value || '{}');
} catch (e) {}
const hiddenField = document.getElementById('provider-options-hidden');
if (hiddenField && jsonTextarea) 
hiddenField.value = jsonTextarea.value;

const excludedCapabilities = [];
schema.fields.forEach(f => {
if (f.capability && ! caps[f.capability]) 
excludedCapabilities.push(f.name);

});
schema.fields.forEach(fieldDef => {
if (fieldDef.capability && ! caps[fieldDef.capability]) 
return;

if (fieldDef.dependsOn && excludedCapabilities.includes(fieldDef.dependsOn)) 
return;

const value = getNestedValue(currentData, fieldDef.name);
const isChecked = value === true || value === 'true';
const fieldValue = value !== undefined ? value : fieldDef.defaultValue;
// Pour provider_region : filtrer les options selon les régions disponibles du modèle
const resolvedFieldDef = (fieldDef.name === 'provider_region' && caps.providerRegions && caps.providerRegions.length > 0)
? { ...fieldDef, options: fieldDef.options.filter(o => o.value === '' || caps.providerRegions.includes(o.value)) }
: fieldDef;
const fieldEl = document.createElement('div');
fieldEl.className = 'synapse-admin-form-group';
fieldEl.id = `field-${
fieldDef.name.replace(/\./g, '-')
}`;
fieldEl.innerHTML = renderField(resolvedFieldDef, fieldValue, isChecked);
fieldEl.setAttribute('data-field-name', fieldDef.name);
if (fieldDef.dependsOn) 
fieldEl.setAttribute('data-depends-on', fieldDef.dependsOn);

container.appendChild(fieldEl);
// Badge RGPD pour le champ provider_region
if (fieldDef.name === 'provider_region') {
const badge = document.createElement('div');
badge.id = 'rgpd-region-badge';
badge.style.marginTop = '6px';
fieldEl.appendChild(badge);
const RGPD_LABELS = {
compliant: { cls: 'rgpd-compliant', title: 'Conforme RGPD — hébergeur et données en UE' },
tolerated: { cls: 'rgpd-tolerated', title: 'Toléré RGPD — données en UE, DPA disponible, pas d\'entraînement (CLOUD Act américain toujours présent)' },
risk:      { cls: 'rgpd-risk',      title: 'Risque RGPD — pays tiers avec protection adéquate (hors UE)' },
danger:    { cls: 'rgpd-danger',    title: 'Non conforme RGPD — données hors UE sans garanties suffisantes' },
unknown:   { cls: 'rgpd-unknown',   title: 'Statut RGPD indéterminé — région non configurée' },
};
const updateRgpdBadge = (region) => {
let status = 'unknown';
if (region === '') status = 'unknown';
else if (region.startsWith('europe-')) status = 'tolerated';
else if (region === 'northamerica-northeast1') status = 'risk';
else status = 'danger';
const { cls, title } = RGPD_LABELS[status];
badge.innerHTML = `<span class="synapse-admin-badge synapse-admin-badge--${cls}" title="${title}">RGPD</span>`;
};
const sel = fieldEl.querySelector('select');
if (sel) {
sel.addEventListener('change', () => updateRgpdBadge(sel.value));
updateRgpdBadge(sel.value);
}
}
const input = fieldEl.querySelector('input, select');
if (input) {
input.addEventListener('change', () => {
updateJsonFromFields();
updateFieldVisibility();
});
input.addEventListener('input', () => updateJsonFromFields());
}
});
if (card) {
const hasFields = container.children.length > 0;
card.style.display = hasFields ? '' : 'none';
if (jsonCard) 
jsonCard.style.display = hasFields ? '' : 'none';

}
updateFieldVisibility();
}

function renderField(fieldDef, value, isChecked) {
let inputHtml = '';
if (fieldDef.type === 'checkbox') {
inputHtml = `<input type="checkbox" id="field-${
fieldDef.name
}" data-field-name="${
fieldDef.name
}" class="synapse-admin-checkbox" ${
isChecked ? 'checked' : ''
}>`;
} else if (fieldDef.type === 'number') {
inputHtml = `<input type="number" id="field-${
fieldDef.name
}" data-field-name="${
fieldDef.name
}" value="${
value || fieldDef.defaultValue || ''
}" min="${
fieldDef.min || 0
}" max="${
fieldDef.max || ''
}" class="synapse-admin-input">`;
} else if (fieldDef.type === 'select') {
const opts = fieldDef.options.map(
o => `<option value="${
o.value
}" ${
o.value === value ? 'selected' : ''
}>${
o.label
}</option>`
).join('');
inputHtml = `<select id="field-${
fieldDef.name
}" data-field-name="${
fieldDef.name
}" class="synapse-admin-select">${opts}</select>`;
}
return `<label class="synapse-admin-label" for="field-${
fieldDef.name
}">${
fieldDef.label
}</label>${inputHtml}<p class="synapse-admin-help">${
fieldDef.help
}</p>`;
}

function updateJsonFromFields() {
const container = document.getElementById('dynamic-provider-ui');
const jsonTextarea = document.getElementById('provider-options-json');
const hiddenField = document.getElementById('provider-options-hidden');
let data = {};
try {
data = JSON.parse(jsonTextarea.value || '{}');
} catch (e) {}container.querySelectorAll('[data-field-name]').forEach(fieldRow => {
const input = fieldRow.querySelector('input, select');
if (! input) 
return;

let value = input.type === 'checkbox' ? input.checked : input.value;
if (input.type === 'number' && value) 
value = parseInt(value, 10);

setNestedValue(data, fieldRow.dataset.fieldName, value);
});
const jsonString = JSON.stringify(data, null, 2);
jsonTextarea.value = jsonString;
hiddenField.value = JSON.stringify(data);
}

function updateFieldVisibility() {
const container = document.getElementById('dynamic-provider-ui');
container.querySelectorAll('[data-depends-on]').forEach(fieldEl => {
const dependsOn = fieldEl.dataset.dependsOn;
const parentFieldRow = container.querySelector (`[data-field-name="${dependsOn}"]`);
if (! parentFieldRow) 
return;

const parentInput = parentFieldRow.querySelector('input, select');
if (! parentInput) 
return;

fieldEl.style.display = (parentInput.type === 'checkbox' ? parentInput.checked : !! parentInput.value) ? '' : 'none';
});
}

function getNestedValue(obj, path) {
return path.split('.').reduce((cur, prop) => cur ?. [prop], obj);
}
function setNestedValue(obj, path, value) {
const keys = path.split('.');
let cur = obj;
for (let i = 0; i < keys.length - 1; i++) {
if (!(keys[i] in cur) || typeof cur[keys[i]] !== 'object') 
cur[keys[i]] = {};

cur = cur[keys[i]];
}
cur[keys[keys.length - 1]] = value;
}

function syncProviderOptionsBeforeSubmit() {
const jsonTextarea = document.getElementById('provider-options-json');
const hiddenField = document.getElementById('provider-options-hidden');
try {
hiddenField.value = JSON.stringify(JSON.parse(jsonTextarea.value || '{}'));
return true;
} catch (e) {
alert('❌ Erreur JSON :\n' + e.message);
return false;
}
}

function updateModelOptions(providerName) {
const select = document.getElementById('model-select');
select.querySelectorAll('optgroup').forEach(g => {
g.style.display = g.dataset.provider === providerName ? '' : 'none';
});
const currentModelId = select.value;
if (! modelCapabilities[currentModelId] || modelCapabilities[currentModelId].provider !== providerName) {
for (const opt of select.querySelectorAll('option')) {
if (opt.dataset.provider === providerName) {
select.value = opt.value;
break;
}
}
}
updateFormVisibility();
}

function updateFormVisibility() {
const modelId = document.getElementById('model-select').value;
const caps = modelCapabilities[modelId] || {
topK: true
};
const el = document.getElementById('section-top-k');
if (el) 
el.style.display = caps.supportsTopK ? '' : 'none';

updateCapsBadges(modelId, caps);
}

function updateModelPricing() {
const modelId = document.getElementById('model-select').value;
const caps = modelCapabilities[modelId];
const container = document.getElementById('model-pricing');
if (!container) return;
if (!caps || (caps.pricingInput == null && caps.pricingOutput == null)) {
container.innerHTML = '<span class="synapse-admin-text-xs synapse-admin-text-tertiary">—</span>';
return;
}
const c = (providerMeta[caps.provider]?.currency === 'EUR') ? '€' : '$';
let lines = [];
if (caps.pricingInput != null) lines.push(`<span class="synapse-admin-text-xs">Input <strong>${c}${caps.pricingInput}</strong>/M tok</span>`);
if (caps.pricingOutput != null) lines.push(`<span class="synapse-admin-text-xs">Output <strong>${c}${caps.pricingOutput}</strong>/M tok</span>`);
if (caps.pricingOutputImage != null && caps.pricingOutputImage > 0) lines.push(`<span class="synapse-admin-text-xs">Image <strong>${c}${caps.pricingOutputImage}</strong>/M tok</span>`);
container.innerHTML = lines.join('');
}
updateModelPricing();

function getDisabledCapabilities() {
const ta = document.getElementById('provider-options-json');
try { return JSON.parse(ta.value).disabled_capabilities || []; } catch(e) { return []; }
}

function setDisabledCapabilities(list) {
const ta = document.getElementById('provider-options-json');
let opts = {};
try { opts = JSON.parse(ta.value); } catch(e) {}
if (list.length === 0) {
delete opts.disabled_capabilities;
} else {
opts.disabled_capabilities = list;
}
ta.value = JSON.stringify(opts, null, 2);
}

function toggleCapability(key) {
let disabled = getDisabledCapabilities();
if (disabled.includes(key)) {
disabled = disabled.filter(k => k !== key);
} else {
disabled.push(key);
}
setDisabledCapabilities(disabled);
}

function updateCapsBadges(modelId, caps) {
const displayEl = document.getElementById('model-caps-display');
if (! displayEl)
return;

const body = displayEl.querySelector('.synapse-admin-card__body');
if (! body)
return;

body.innerHTML = '';
const capabilities = [
{
capsKey: 'supportsTextGeneration',
disableKey: null,
label: 'Text Generation',
icon: 'message-square-text',
desc: 'Génération de texte (chat / completion). Le modèle peut produire des réponses textuelles.',
infoOnly: true
}, {
capsKey: 'supportsEmbedding',
disableKey: null,
label: 'Embedding',
icon: 'database',
desc: 'Génération d\'embeddings vectoriels. Utilisé pour la recherche sémantique et le RAG.',
infoOnly: true
}, {
capsKey: 'supportsImageGeneration',
disableKey: null,
label: 'Image Generation',
icon: 'image',
desc: 'Génération d\'images (text-to-image). Le modèle peut produire des images à partir de descriptions textuelles.',
infoOnly: true
}, {
capsKey: 'supportsThinking',
disableKey: 'thinking',
label: 'Thinking',
icon: 'brain',
desc: 'Raisonnement avancé (chain-of-thought). Le modèle réfléchit avant de répondre pour des tâches complexes.'
}, {
capsKey: 'supportsFunctionCalling',
disableKey: 'function_calling',
label: 'Tool Calls',
icon: 'wrench',
desc: 'Appels d\'outils (function calling). Le modèle peut déclencher des fonctions externes pendant la conversation.'
}, {
capsKey: 'supportsSafetySettings',
disableKey: 'safety_settings',
label: 'Safety Filters',
icon: 'shield',
desc: 'Filtres de sécurité configurables (harcèlement, contenu explicite, etc.).'
}, {
capsKey: 'supportsStreaming',
disableKey: 'streaming',
label: 'Streaming',
icon: 'activity',
desc: 'Réponse en temps réel (SSE). Les tokens s\'affichent au fur et à mesure. Désactiver pour passer en mode synchrone (debug).'
}, {
capsKey: 'supportsVision',
disableKey: 'vision',
label: 'Vision',
icon: 'eye',
desc: 'Analyse d\'images en entrée. Permet d\'envoyer des photos ou captures d\'écran dans la conversation.'
}, {
capsKey: 'supportsParallelToolCalls',
disableKey: null,
label: 'Parallel Tools',
icon: 'git-fork',
desc: 'Le modèle peut exécuter plusieurs outils simultanément. Comportement automatique du modèle, non configurable.',
infoOnly: true
}, {
capsKey: 'supportsResponseSchema',
disableKey: 'response_schema',
label: 'JSON Mode',
icon: 'braces',
desc: 'Sortie structurée en JSON (Structured Output). Force le modèle à répondre selon un schéma JSON défini.',
notImplemented: true
}
];
const disabled = getDisabledCapabilities();
for (const {capsKey: key, disableKey, label, icon, desc, notImplemented, infoOnly} of capabilities) {
const isSupported = !!caps[key];
const isDisabled = disableKey && disabled.includes(disableKey);
const pill = document.createElement('span');
if (!isSupported) {
pill.className = 'synapse-admin-badge synapse-admin-badge--danger';
pill.style.opacity = '0.65';
pill.style.textDecoration = 'line-through';
pill.setAttribute('data-synapse-admin-tooltip', `Non supporté par ce modèle. ${desc}`);
pill.innerHTML = `<i data-lucide="${icon}"></i> ${label}`;
} else if (notImplemented) {
pill.className = 'synapse-admin-badge synapse-admin-badge--neutral';
pill.style.opacity = '0.65';
pill.setAttribute('data-synapse-admin-tooltip', `${desc} — Implémentation à venir.`);
pill.innerHTML = `<i data-lucide="clock"></i> ${label}`;
} else if (infoOnly) {
pill.className = 'synapse-admin-badge synapse-admin-badge--info';
pill.setAttribute('data-synapse-admin-tooltip', desc);
pill.innerHTML = `<i data-lucide="${icon}"></i> ${label}`;
} else {
pill.className = isDisabled ? 'synapse-admin-badge synapse-admin-badge--neutral' : 'synapse-admin-badge synapse-admin-badge--success';
pill.style.cursor = 'pointer';
pill.style.userSelect = 'none';
if (isDisabled) pill.style.opacity = '0.55';
const actionHint = isDisabled ? 'Cliquer pour réactiver.' : 'Cliquer pour désactiver dans ce preset.';
pill.setAttribute('data-synapse-admin-tooltip', `${desc} — ${actionHint}`);
pill.innerHTML = `<i data-lucide="${isDisabled ? 'x-circle' : icon}"></i> ${label}`;
pill.addEventListener('click', () => { toggleCapability(disableKey); updateCapsBadges(modelId, caps); });
}
body.appendChild(pill);
}
if (typeof lucide !== 'undefined') lucide.createIcons();

}

document.addEventListener('DOMContentLoaded', () => {
const providerSelect = document.getElementById('provider-select');
const modelSelect = document.getElementById('model-select');
providerSelect.addEventListener('change', e => {
updateModelOptions(e.target.value);
renderDynamicFields(e.target.value);
});
modelSelect.addEventListener('change', () => {
updateFormVisibility();
renderDynamicFields(providerSelect.value);
});
const jsonTextarea = document.getElementById('provider-options-json');
if (jsonTextarea)
jsonTextarea.addEventListener('change', () => {
renderDynamicFields(providerSelect.value);
const modelId = document.getElementById('model-select').value;
const caps = modelCapabilities[modelId] || {};
updateCapsBadges(modelId, caps);
});

updateModelOptions(providerSelect.value);
updateFormVisibility();
renderDynamicFields(providerSelect.value);
});
	</script>

{% endblock %}
