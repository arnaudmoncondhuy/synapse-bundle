{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.workflow.list.page_title'|trans(domain='synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="{{ path('synapse_admin_providers') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-current">{{ 'synapse.admin.sidebar.workflows'|trans(domain='synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="workflow"></i>
				</span>
				{{ 'synapse.admin.workflow.list.title'|trans(domain='synapse_admin') }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ 'synapse.admin.workflow.list.subtitle'|trans(domain='synapse_admin') }}
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_workflows_new') }}" class="synapse-admin-btn synapse-admin-btn--primary">
				<i data-lucide="plus"></i>
				{{ 'synapse.admin.workflow.list.action.new'|trans(domain='synapse_admin') }}
			</a>
		</div>
	</div>

	<div class="synapse-admin-grid synapse-admin-grid--2">
		{% for workflow in workflows %}
			{% set counts = runs_counts[workflow.id] ?? {} %}
			{% set total_runs = 0 %}
			{% for _, count in counts %}{% set total_runs = total_runs + count %}{% endfor %}

			<div class="synapse-admin-card synapse-admin-card--hover {{ not workflow.isActive ? 'synapse-admin-card--inactive' : '' }}">

				<div class="synapse-admin-card__header">
					<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
						<i data-lucide="git-branch"></i>
					</div>

					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm">
						<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm">
							<span class="synapse-admin-card__title">{{ workflow.name }}</span>
							{% if workflow.isBuiltin %}
								<span class="synapse-admin-badge synapse-admin-badge--neutral" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.list.badge.builtin_tooltip'|trans(domain='synapse_admin') }}">
									<i data-lucide="lock"></i>
									{{ 'synapse.admin.workflow.list.badge.builtin'|trans(domain='synapse_admin') }}
								</span>
							{% endif %}
							{% if not workflow.isActive %}
								<span class="synapse-admin-badge synapse-admin-badge--warning">
									<i data-lucide="eye-off"></i>
									{{ 'synapse.admin.workflow.list.badge.disabled'|trans(domain='synapse_admin') }}
								</span>
							{% endif %}
							<span class="synapse-admin-badge synapse-admin-badge--info" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.list.badge.version_tooltip'|trans(domain='synapse_admin') }}">
								v{{ workflow.version }}
							</span>
						</div>
						<div class="synapse-admin-text-sm synapse-admin-text-muted">
							<code class="synapse-admin-font-mono" style="font-size: 0.75rem;">{{ workflow.workflowKey }}</code>
						</div>
					</div>
				</div>

				<div class="synapse-admin-card__body synapse-admin-card__body--compact">
					{% if workflow.description %}
						<p class="synapse-admin-text-sm synapse-admin-text-muted synapse-admin-mb-md">{{ workflow.description }}</p>
					{% endif %}

					<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm synapse-admin-text-xs synapse-admin-text-muted">
						<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
							<i data-lucide="list-ordered" style="width: 1rem; height: 1rem;"></i>
							<span><strong>{{ 'synapse.admin.workflow.list.label.steps'|trans(domain='synapse_admin') }} :</strong> {{ workflow.stepsCount }}</span>
						</div>
						<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
							<i data-lucide="play" style="width: 1rem; height: 1rem;"></i>
							<span><strong>{{ 'synapse.admin.workflow.list.label.runs'|trans(domain='synapse_admin') }} :</strong> {{ total_runs }}</span>
						</div>
					</div>
				</div>

				<div class="synapse-admin-card__footer">
					<div class="synapse-admin-flex synapse-admin-gap-md synapse-admin-items-center">

						<a href="{{ path('synapse_admin_workflows_edit', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.list.tooltip.edit'|trans(domain='synapse_admin') }}">
							<i data-lucide="edit-3"></i>
						</a>

						<a href="{{ path('synapse_admin_workflows_runs', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm" data-synapse-admin-tooltip="{{ 'synapse.admin.workflow.list.tooltip.runs'|trans(domain='synapse_admin') }}">
							<i data-lucide="activity"></i>
						</a>

						<form action="{{ path('synapse_admin_workflows_toggle', {id: workflow.id}) }}" method="POST" class="synapse-admin-form-inline">
							<input type="hidden" name="_token" value="{{ csrf_token('synapse_workflow_toggle_' ~ workflow.id) }}">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm"
									data-synapse-admin-tooltip="{{ workflow.isActive ? 'synapse.admin.workflow.list.tooltip.disable'|trans(domain='synapse_admin') : 'synapse.admin.workflow.list.tooltip.enable'|trans(domain='synapse_admin') }}">
								{% if workflow.isActive %}
									<i data-lucide="eye-off"></i>
								{% else %}
									<i data-lucide="eye"></i>
								{% endif %}
							</button>
						</form>

						<form action="{{ path('synapse_admin_workflows_delete', {id: workflow.id}) }}" method="POST" class="synapse-admin-form-inline"
							{% if not workflow.isBuiltin %}onsubmit="return confirm('{{ 'synapse.admin.workflow.list.confirm_delete'|trans({'name': workflow.name}, domain='synapse_admin')|escape('js') }}')"{% endif %}>
							<input type="hidden" name="_token" value="{{ csrf_token('synapse_workflow_delete_' ~ workflow.id) }}">
							<button type="submit" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm synapse-admin-text-danger"
									data-synapse-admin-tooltip="{{ workflow.isBuiltin ? 'synapse.admin.workflow.list.tooltip.builtin_no_delete'|trans(domain='synapse_admin') : 'synapse.admin.workflow.list.tooltip.delete'|trans(domain='synapse_admin') }}"
									{% if workflow.isBuiltin %}disabled{% endif %}>
								<i data-lucide="trash-2"></i>
							</button>
						</form>

					</div>
				</div>

			</div>
		{% else %}
			<div class="synapse-admin-empty-state" style="grid-column: 1 / -1;">
				<i data-lucide="workflow" class="synapse-admin-empty-state__icon"></i>
				<p class="synapse-admin-empty-state__title">{{ 'synapse.admin.workflow.list.empty.title'|trans(domain='synapse_admin') }}</p>
				<p class="synapse-admin-empty-state__subtitle">{{ 'synapse.admin.workflow.list.empty.subtitle'|trans(domain='synapse_admin') }}</p>
				<a href="{{ path('synapse_admin_workflows_new') }}" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-mt-md">
					<i data-lucide="plus"></i>
					{{ 'synapse.admin.workflow.list.empty.action'|trans(domain='synapse_admin') }}
				</a>
			</div>
		{% endfor %}
	</div>

	{# ─── Workflows éphémères (sandbox) — créés par les outils MCP / LLM ─── #}
	{% if sandbox_workflows is defined and sandbox_workflows|length > 0 %}
		<div class="synapse-admin-page-header synapse-admin-mt-xl">
			<div class="synapse-admin-page-header__info">
				<h2 class="synapse-admin-page-title" style="font-size: 1.25rem;">
					<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--warning">
						<i data-lucide="sparkles"></i>
					</span>
					Workflows éphémères récents
				</h2>
				<p class="synapse-admin-page-subtitle">
					Workflows créés à la volée par un LLM via MCP (ou par une conversation Synapse). Ils ne sont pas listés dans les workflows principaux. Promeus ceux qui méritent d'être conservés — ils deviendront éditables et planifiables comme un workflow normal.
				</p>
			</div>
		</div>

		<div class="synapse-admin-grid synapse-admin-grid--2">
			{% for workflow in sandbox_workflows %}
				<div class="synapse-admin-card synapse-admin-card--hover" style="border-left: 3px solid var(--synapse-admin-color-warning, #f59e0b);">
					<div class="synapse-admin-card__header">
						<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--warning">
							<i data-lucide="sparkles"></i>
						</div>
						<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm">
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm">
								<span class="synapse-admin-card__title">{{ workflow.name }}</span>
								<span class="synapse-admin-badge synapse-admin-badge--warning" data-synapse-admin-tooltip="Créé à la volée par un outil MCP ou un LLM. Non visible dans la liste principale tant qu'il n'est pas promu.">
									<i data-lucide="sparkles"></i>
									éphémère
								</span>
								<span class="synapse-admin-badge synapse-admin-badge--info">
									v{{ workflow.version }}
								</span>
							</div>
							<div class="synapse-admin-text-sm synapse-admin-text-muted">
								<code class="synapse-admin-font-mono" style="font-size: 0.75rem;">{{ workflow.workflowKey }}</code>
							</div>
						</div>
					</div>

					<div class="synapse-admin-card__body synapse-admin-card__body--compact">
						{% if workflow.description %}
							<p class="synapse-admin-text-sm synapse-admin-text-muted synapse-admin-mb-md">{{ workflow.description }}</p>
						{% endif %}
						<div class="synapse-admin-flex synapse-admin-flex-col synapse-admin-gap-sm synapse-admin-text-xs synapse-admin-text-muted">
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
								<i data-lucide="list-ordered" style="width: 1rem; height: 1rem;"></i>
								<span><strong>Étapes :</strong> {{ workflow.stepsCount }}</span>
							</div>
							<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-xs">
								<i data-lucide="clock" style="width: 1rem; height: 1rem;"></i>
								<span><strong>Créé :</strong> {{ workflow.createdAt|date('d/m/Y H:i') }}</span>
							</div>
						</div>
					</div>

					<div class="synapse-admin-card__footer">
						<div class="synapse-admin-flex synapse-admin-gap-md synapse-admin-items-center">
							<a href="{{ path('synapse_admin_workflows_edit', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm" data-synapse-admin-tooltip="Consulter la structure (steps, JSON, agents)">
								<i data-lucide="eye"></i>
							</a>

							<a href="{{ path('synapse_admin_workflows_runs', {id: workflow.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--icon synapse-admin-btn--sm" data-synapse-admin-tooltip="Voir les runs">
								<i data-lucide="activity"></i>
							</a>

							<form action="{{ path('synapse_admin_workflows_promote', {id: workflow.id}) }}" method="POST" class="synapse-admin-form-inline"
								onsubmit="return confirm('Promouvoir « {{ workflow.name|escape('js') }} » en workflow persistant ? Il apparaîtra dans la liste principale et deviendra éditable.')">
								<input type="hidden" name="_token" value="{{ csrf_token('synapse_workflow_promote_' ~ workflow.id) }}">
								<button type="submit" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
									<i data-lucide="arrow-up-circle"></i>
									Promouvoir
								</button>
							</form>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	{% endif %}

{% endblock %}
