{% block admin_page_title %}Analytics | Usage | Synapse Administration Synapse
{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="#" class="synapse-admin-topbar__breadcrumb">Usage</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">Analytics</span>
{% endblock %}

{% block admin_content %}

	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--indigo">
					<i data-lucide="bar-chart-3"></i>
				</span>
				Statistiques d'Usage
			</h1>
			<p class="synapse-admin-page-subtitle">
				Analysez la consommation de tokens et les coûts associés sur les {{ period_label }}.
			</p>
		</div>
		<div class="synapse-admin-page-header__actions">
			<a href="{{ path('synapse_admin_quotas') }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
				<i data-lucide="gauge"></i>
				Quotas & Budget
			</a>
			<a href="#" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
				<i data-lucide="download"></i>
				Exporter
			</a>
		</div>
	</div>

	{# ── KPI Globaux ────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-grid synapse-admin-grid--2 synapse-admin-mb-lg">
		<div class="synapse-admin-kpi">
			<div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--indigo">
				<i data-lucide="coins"></i>
			</div>
			<div class="synapse-admin-kpi__content">
				<div class="synapse-admin-kpi__label">Coût total estimé</div>
				<div class="synapse-admin-kpi__value">{{ costs_eur|number_format(2) }} €</div>
				{% if costs_usd > 0 %}
					<div class="synapse-admin-kpi__trend synapse-admin-text-xs">
						({{ costs_usd|number_format(2) }} $)
					</div>
				{% endif %}
			</div>
		</div>

		<div class="synapse-admin-kpi">
			<div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--indigo">
				<i data-lucide="cpu"></i>
			</div>
			<div class="synapse-admin-kpi__content">
				<div class="synapse-admin-kpi__label">Consommation LLM</div>
				<div class="synapse-admin-kpi__value">{{ (stats.total_tokens ?? 0)|number_format(0, '', ' ') }}</div>
				<div class="synapse-admin-kpi__trend synapse-admin-text-xs">
					Tokens total
				</div>
			</div>
		</div>
	</div>

	{# ── Sélecteur de période ─────────────────────────────────────────────────── #}
	<div class="synapse-admin-flex synapse-admin-justify-between synapse-admin-items-center synapse-admin-mb-md">
		<h2 class="synapse-admin-page-title synapse-admin-page-title--sm">Tendance quotidienne</h2>
		<div class="synapse-admin-flex synapse-admin-gap-xs">
			{% for days, label in {7: '7 jours', 30: '30 jours', 90: '3 mois'} %}
				<a href="{{ path('synapse_admin_analytics', {period: days}) }}" class="synapse-admin-btn synapse-admin-btn--sm {{ period == days ? 'synapse-admin-btn--primary' : 'synapse-admin-btn--ghost' }}">
					{{ label }}
				</a>
			{% endfor %}
		</div>
	</div>

	{# ── Graphique (CSS simpliste pour placeholder) ─────────────────────────── #}
	<div class="synapse-admin-card synapse-admin-mb-xl">
		<div class="synapse-admin-card__body">
			<div style="height: 120px; display: flex; align-items: flex-end; gap: 4px; padding: 10px 0;">
				{% if daily_usage is empty %}
					<div class="synapse-admin-text-secondary synapse-admin-w-full synapse-admin-text-center">Aucune donnée disponible pour cette période.</div>
				{% else %}
					{% set max_tokens = 1 %}
					{% for day in daily_usage %}
						{% if (day.total_tokens ?? 0) > max_tokens %}
							{% set max_tokens = day.total_tokens %}
						{% endif %}
					{% endfor %}

					{% for day in daily_usage %}
						<div class="synapse-admin-bg-indigo" style="flex: 1; height: {{ max_tokens > 0 ? ((day.total_tokens ?? 0) / max_tokens * 100)|round : 0 }}%; min-width: 8px; border-radius: 2px; opacity: 0.8;" title="{{ day.date }} : {{ day.total_tokens }} tokens"></div>
					{% endfor %}
				{% endif %}
			</div>
			<div class="synapse-admin-flex synapse-admin-justify-between synapse-admin-text-xs synapse-admin-text-secondary synapse-admin-mt-sm">
				<span>Il y a {{ period }} jours</span>
				<span>Aujourd'hui</span>
			</div>
		</div>
	</div>

	{# ── Répartition ────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-grid synapse-admin-grid--2">
		{# Par Module #}
		<div class="synapse-admin-card">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon">
					<i data-lucide="layers"></i>
				</div>
				<div class="synapse-admin-card__title">Répartition par Module</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				{% if usage_by_module is empty %}
					<p class="synapse-admin-text-secondary">Aucune donnée par module.</p>
				{% else %}
					<div class="synapse-admin-table-wrapper">
						<table class="synapse-admin-table">
							<thead>
								<tr>
									<th>Module</th>
									<th class="synapse-admin-text-right">Requêtes</th>
									<th class="synapse-admin-text-right">Tokens</th>
								</tr>
							</thead>
							<tbody>
								{% for module, data in usage_by_module %}
									<tr>
										<td>
											<div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-sm">
												<i data-lucide="{{ module == 'chat' ? 'message-circle' : (module == 'embedding' ? 'database-zap' : (module == 'agent' ? 'bot' : 'cpu')) }}" class="synapse-admin-text-secondary" style="width: 14px; height: 14px;"></i>
												<span>
													{% if module == 'chat' %}Conversation
													{% elseif module == 'agent' %}Agent
													{% elseif module == 'embedding' %}Embedding
													{% else %}{{ module|capitalize }}{% endif %}
												</span>
											</div>
										</td>
										<td class="synapse-admin-text-right">{{ data.count }}</td>
										<td class="synapse-admin-text-right synapse-admin-font-mono">{{ (data.total_tokens ?? 0)|number_format(0, '', ' ') }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% endif %}
			</div>
		</div>

		{# Par Modèle #}
		<div class="synapse-admin-card">
			<div class="synapse-admin-card__header">
				<div class="synapse-admin-card__header-icon">
					<i data-lucide="brain-circuit"></i>
				</div>
				<div class="synapse-admin-card__title">Répartition par Modèle</div>
			</div>
			<div class="synapse-admin-card__body synapse-admin-card__body--compact">
				{% if usage_by_model is empty %}
					<p class="synapse-admin-text-secondary">Aucune donnée par modèle.</p>
				{% else %}
					<div class="synapse-admin-table-wrapper">
						<table class="synapse-admin-table">
							<thead>
								<tr>
									<th>Modèle</th>
									<th class="synapse-admin-text-right">Tokens</th>
									<th class="synapse-admin-text-right">Coût (Ref)</th>
								</tr>
							</thead>
							<tbody>
								{% for modelId, data in usage_by_model %}
									<tr>
										<td class="synapse-admin-text-xs synapse-admin-font-mono">{{ modelId }}</td>
										<td class="synapse-admin-text-right">{{ (data.total_tokens ?? 0)|number_format(0, '', ' ') }}</td>
										<td class="synapse-admin-text-right">{{ (data.cost ?? 0)|number_format(4) }} {{ data.currency ?? 'EUR' }}</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% endif %}
			</div>
		</div>
	</div>

	{# ── Détails Conversations ──────────────────────────────────────────────── #}
	<div class="synapse-admin-card synapse-admin-mt-lg">
		<div class="synapse-admin-card__header">
			<div class="synapse-admin-card__header-icon">
				<i data-lucide="messages-square"></i>
			</div>
			<div>
				<div class="synapse-admin-card__title">Activité Conversationnelle</div>
				<div class="synapse-admin-card__subtitle">Détails des échanges via le chat</div>
			</div>
		</div>
		<div class="synapse-admin-card__body synapse-admin-card__body--compact">
			<div class="synapse-admin-grid synapse-admin-grid--2">
				<div class="synapse-admin-flex synapse-admin-flex-col">
					<span class="synapse-admin-text-xs synapse-admin-text-secondary">Nombre de tours de parole</span>
					<span class="synapse-admin-text-lg synapse-admin-font-bold">{{ (conversation_stats.count ?? 0)|number_format(0, '', ' ') }}</span>
				</div>
				<div class="synapse-admin-flex synapse-admin-flex-col">
					<span class="synapse-admin-text-xs synapse-admin-text-secondary">Tokens cumulés</span>
					<span class="synapse-admin-text-lg synapse-admin-font-bold">{{ (conversation_stats.total_tokens ?? 0)|number_format(0, '', ' ') }}</span>
				</div>
			</div>
		</div>
	</div>

{% endblock %}
