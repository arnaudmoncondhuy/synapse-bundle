{#
    Synapse Administration — Base Layout

    En mode standalone (synapse.admin_outer_layout: null) :
        Étend _standalone.html.twig → page HTML complète autonome.

    En mode intégré (synapse.admin_outer_layout: 'core/base.html.twig') :
        Étend le layout de l'app hôte, exactement comme le composant chat.
        Le shell admin (sidebar + contenu) s'insère dans {% block body %}.

    BLOCS DISPONIBLES POUR LES PAGES ADMIN :
    - admin_page_title      : Titre de l'onglet
    - admin_breadcrumb      : Fil d'Ariane dans la topbar
    - admin_topbar_actions  : Boutons/actions à droite de la topbar
    - admin_content         : Zone de contenu principale ← À surcharger
#}
{% extends synapse_admin_outer_layout ?? '@Synapse/admin/layout/_standalone.html.twig' %}

{# ── Titre de page ─────────────────────────────────────────────────────────── #}
{% block title %}{% block admin_page_title %}{{ 'synapse.admin.title'|trans(domain: 'synapse_admin') }}{% endblock %}{% endblock %}

{# ── CSS admin + CSRF meta ────────────────────────────────────────────────── #}
{% block stylesheets %}
    {{ parent() }}

    {# CSRF token global pour les actions admin #}
    <meta name="synapse-csrf" content="{{ csrf_token('synapse_admin') }}">

    {# Google Fonts : Plus Jakarta Sans #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

    {# Synapse Design System #}
    <link rel="stylesheet" href="{{ asset('synapse-admin/styles/admin/admin.css') }}">

    {# Slot pour surcharger les tokens de couleur (thème projet) #}
    {% block admin_theme %}{% endblock %}

    {% block admin_stylesheets %}{% endblock %}
{% endblock %}

{# ── Shell admin (sidebar + main) ─────────────────────────────────────────── #}
{% block body %}
<div class="synapse-admin-shell">

    {# ═══════════════════════════════════════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════════════════════════════════════ #}
    {% block admin_sidebar %}
        {{ include('@Synapse/admin/layout/_sidebar.html.twig') }}
    {% endblock %}

    {# ═══════════════════════════════════════════════════════════════════════
       MAIN
       ═══════════════════════════════════════════════════════════════════════ #}
    <main class="synapse-admin-main">

        {# Topbar sticky #}
        <div class="synapse-admin-topbar">
            <nav class="synapse-admin-topbar__breadcrumb" aria-label="{{ 'synapse.admin.breadcrumb.label'|trans(domain: 'synapse_admin') }}">
                <a href="{{ path('synapse_admin_dashboard') }}">
                    <i data-lucide="home" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:4px;"></i>{{ 'synapse.admin.topbar.home'|trans(domain: 'synapse_admin') }}
                </a>
                {% block admin_breadcrumb %}{% endblock %}
            </nav>

            <div class="synapse-admin-topbar__actions">
                {% block admin_topbar_actions %}{% endblock %}
            </div>
        </div>

        {# Flash messages #}
        {% block admin_flash %}
            {{ include('@Synapse/admin/layout/_flash.html.twig') }}
        {% endblock %}

        {# Contenu de la page #}
        <div class="synapse-admin-content">
            {% block admin_content %}{% endblock %}
        </div>

    </main>
</div>

{# Scripts (lucide init + tooltips) — en dehors du shell pour le DOM complet #}
{% block admin_body_scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }

            // ── Tooltip JS global pour les éléments dans .synapse-admin-card ────────────
            // Les tooltips CSS sont bloqués par overflow:hidden des cartes.
            // Ce système crée un élément fixe sur le body, jamais clippé.
            const tip = document.createElement('div');
            tip.id = 'synapse-admin-tooltip-global';
            document.body.appendChild(tip);

            document.addEventListener('mouseenter', function (e) {
                const el = e.target.closest('[data-synapse-admin-tooltip]');
                if (!el) return;
                const text = el.getAttribute('data-synapse-admin-tooltip');
                if (!text) return;
                tip.textContent = text;
                tip.style.opacity = '1';
                positionTip(e, el);
            }, true);
            document.addEventListener('mouseleave', function (e) {
                if (e.target.closest('[data-synapse-admin-tooltip]')) tip.style.opacity = '0';
            }, true);
            document.addEventListener('mousemove', function (e) {
                const el = e.target.closest('[data-synapse-admin-tooltip]');
                if (el && tip.style.opacity === '1') positionTip(e, el);
            }, true);

            function positionTip(e, el) {
                const rect = el.getBoundingClientRect();
                tip.style.left = (rect.left + rect.width / 2) + 'px';
                tip.style.top  = (rect.top - 36) + 'px';
            }
        });
    </script>
{% endblock %}
{% endblock %}
