{#
    Synapse Administration Synapse — Sidebar Navigation

    Structure :
    - Tableau de bord
    - 🧠 Intelligence  : Configuration LLM (hub onglets) · Assistants · Outils · Personnalité · Configuration globale
    - 🧩 Base de connaissance : Configuration (embeddings/RAG)
    - 📈 Monitoring    : Analytics · Quotas · Export
    - 🔒 Sécurité      : Audit & Logs · RGPD
    - ⚙️  Système       : Debug · Santé · À propos
#}
{% set route = app.request.attributes.get('_route') %}

<aside class="synapse-admin-sidebar" role="navigation" aria-label="{{ 'synapse.admin.sidebar.aria.navigation'|trans(domain='synapse_admin') }}">

    {# ── Marque ────────────────────────────────────────────────────────── #}
    <a href="{{ path('synapse_admin_dashboard') }}" class="synapse-admin-brand">
        <div class="synapse-admin-brand__logo" aria-hidden="true">
            <i data-lucide="brain-circuit"></i>
        </div>
        <span class="synapse-admin-brand__name">Synapse</span>
    </a>

    {# ── Navigation ────────────────────────────────────────────────────── #}
    <nav class="synapse-admin-nav" aria-label="{{ 'synapse.admin.sidebar.aria.menu'|trans(domain='synapse_admin') }}">

        {# ── Tableau de bord ──────────────────────────────────────────── #}
        <div class="synapse-admin-nav__group">
            <a href="{{ path('synapse_admin_dashboard') }}"
               class="synapse-admin-nav__link {% if route == 'synapse_admin_dashboard' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="layout-dashboard"></i></span>
                {{ 'synapse.admin.sidebar.dashboard'|trans(domain='synapse_admin') }}
            </a>
        </div>

        {# ─────────────────────────────────────────────────────────────── #}
        {# 🧠 INTELLIGENCE                                                 #}
        {# ─────────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-nav__section">🧠 {{ 'synapse.admin.sidebar.section.intelligence'|trans(domain='synapse_admin') }}</div>
        <div class="synapse-admin-nav__group">

            {# Configuration LLM — hub onglets (fournisseurs + modèles + presets) #}
            <a href="{{ path('synapse_admin_configuration_llm') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_configuration_llm' or route starts with 'synapse_admin_providers' or route starts with 'synapse_admin_models' or route starts with 'synapse_admin_presets' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="settings-2"></i></span>
                {{ 'synapse.admin.sidebar.llm_config'|trans(domain='synapse_admin') }}
            </a>

            {# Agents (ex Missions) #}
            <a href="{{ path('synapse_admin_agents') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_agents' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="bot"></i></span>
                {{ 'synapse.admin.sidebar.agents'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_tools') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_tools' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="wrench"></i></span>
                {{ 'synapse.admin.sidebar.tools'|trans(domain='synapse_admin') }}
            </a>

            {# Personnalité (ex Tons de réponse) #}
            <a href="{{ path('synapse_admin_tones') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_tones' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="mic-2"></i></span>
                {{ 'synapse.admin.sidebar.tones'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_settings') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_settings' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="settings"></i></span>
                {{ 'synapse.admin.sidebar.global_config'|trans(domain='synapse_admin') }}
            </a>

        </div>


        {# ─────────────────────────────────────────────────────────────── #}
        {# 🧩 BASE DE CONNAISSANCE                                         #}
        {# ─────────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-nav__section">🧩 {{ 'synapse.admin.sidebar.section.knowledge'|trans(domain='synapse_admin') }}</div>
        <div class="synapse-admin-nav__group">

            <a href="{{ path('synapse_admin_embeddings') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_embeddings' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="database-zap"></i></span>
                {{ 'synapse.admin.sidebar.settings'|trans(domain='synapse_admin') }}
            </a>

        </div>

        {# ─────────────────────────────────────────────────────────────── #}
        {# 📈 MONITORING                                                   #}
        {# ─────────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-nav__section">📈 {{ 'synapse.admin.sidebar.section.monitoring'|trans(domain='synapse_admin') }}</div>
        <div class="synapse-admin-nav__group">

            <a href="{{ path('synapse_admin_analytics') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_analytics' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="bar-chart-3"></i></span>
                {{ 'synapse.admin.sidebar.analytics'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_quotas') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_quotas' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="gauge"></i></span>
                {{ 'synapse.admin.sidebar.quotas'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_spending_alerts') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_spending_alerts' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="triangle-alert"></i></span>
                {{ 'synapse.admin.sidebar.spending_alerts'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_export') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_export' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="download"></i></span>
                {{ 'synapse.admin.sidebar.export'|trans(domain='synapse_admin') }}
                <span class="synapse-admin-nav__badge">{{ 'synapse.admin.common.soon'|trans(domain='synapse_admin') }}</span>
            </a>

        </div>

        {# ─────────────────────────────────────────────────────────────── #}
        {# 🔒 SÉCURITÉ                                                     #}
        {# ─────────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-nav__section">🔒 {{ 'synapse.admin.sidebar.section.security'|trans(domain='synapse_admin') }}</div>
        <div class="synapse-admin-nav__group">

            <a href="{{ path('synapse_admin_audit') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_audit' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="scroll-text"></i></span>
                {{ 'synapse.admin.sidebar.audit'|trans(domain='synapse_admin') }}
            </a>

<a href="{{ path('synapse_admin_gdpr') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_gdpr' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="shield-check"></i></span>
                {{ 'synapse.admin.sidebar.gdpr'|trans(domain='synapse_admin') }}
            </a>

        </div>

        {# ─────────────────────────────────────────────────────────────── #}
        {# ⚙️ SYSTÈME                                                      #}
        {# ─────────────────────────────────────────────────────────────── #}
        <div class="synapse-admin-nav__section">⚙️ {{ 'synapse.admin.sidebar.section.system'|trans(domain='synapse_admin') }}</div>
        <div class="synapse-admin-nav__group">

            <a href="{{ path('synapse_admin_debug') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_debug' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="bug"></i></span>
                {{ 'synapse.admin.sidebar.debug'|trans(domain='synapse_admin') }}
            </a>

            <a href="{{ path('synapse_admin_health') }}"
               class="synapse-admin-nav__link {% if route starts with 'synapse_admin_health' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="heart-pulse"></i></span>
                {{ 'synapse.admin.sidebar.health'|trans(domain='synapse_admin') }}
                <span class="synapse-admin-nav__badge">{{ 'synapse.admin.common.soon'|trans(domain='synapse_admin') }}</span>
            </a>

            <a href="{{ path('synapse_admin_about') }}"
               class="synapse-admin-nav__link {% if route == 'synapse_admin_about' %}is-active{% endif %}">
                <span class="synapse-admin-nav__icon"><i data-lucide="info"></i></span>
                {{ 'synapse.admin.sidebar.about'|trans(domain='synapse_admin') }}
            </a>

        </div>

    </nav>

    {# ── Footer ────────────────────────────────────────────────────────── #}
    <div class="synapse-admin-sidebar-footer">
        <div style="flex:1; min-width:0;">
            <div class="synapse-admin-sidebar-footer__text">
                <i data-lucide="package" style="width:12px;height:12px;display:inline-block;vertical-align:middle;margin-right:4px;"></i>
                SynapseBundle
            </div>
            <div class="synapse-admin-sidebar-footer__version">{{ synapse_version() }}</div>
        </div>
    </div>

</aside>
