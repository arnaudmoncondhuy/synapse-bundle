{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.rag.documents.page_title'|trans({name: source.name}, domain: 'synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.memory'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="{{ path('synapse_admin_rag_sources') }}" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.rag_sources'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="{{ path('synapse_admin_rag_sources_edit', {id: source.id}) }}" class="synapse-admin-topbar__breadcrumb">{{ source.name }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <span class="synapse-admin-topbar__current">{{ 'synapse.admin.rag.documents.breadcrumb'|trans(domain: 'synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

    <div class="synapse-admin-page-header">
        <div class="synapse-admin-page-header__info">
            <h1 class="synapse-admin-page-title">
                <span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
                    <i data-lucide="file-text"></i>
                </span>
                {{ 'synapse.admin.rag.documents.title'|trans({name: source.name}, domain: 'synapse_admin') }}
            </h1>
            <p class="synapse-admin-page-subtitle">
                {{ 'synapse.admin.rag.documents.subtitle'|trans({total: total}, domain: 'synapse_admin') }}
            </p>
        </div>
        <div class="synapse-admin-page-header__actions">
            <a href="{{ path('synapse_admin_rag_sources_edit', {id: source.id}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                <i data-lucide="arrow-left"></i>
                {{ 'synapse.admin.rag.documents.action.back'|trans(domain: 'synapse_admin') }}
            </a>
        </div>
    </div>

    <div class="synapse-admin-card">
        <div class="synapse-admin-table-container">
            <table class="synapse-admin-table">
                <thead>
                    <tr>
                        <th>{{ 'synapse.admin.rag.documents.table.head.content'|trans(domain: 'synapse_admin') }}</th>
                        <th>{{ 'synapse.admin.rag.documents.table.head.identifier'|trans(domain: 'synapse_admin') }}</th>
                        <th>{{ 'synapse.admin.rag.documents.table.head.chunk'|trans(domain: 'synapse_admin') }}</th>
                        <th>{{ 'synapse.admin.rag.documents.table.head.metadata'|trans(domain: 'synapse_admin') }}</th>
                        <th>{{ 'synapse.admin.rag.documents.table.head.created_at'|trans(domain: 'synapse_admin') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for doc in documents %}
                        <tr>
                            <td>
                                <div class="synapse-admin-truncate" style="max-width: 400px;" data-synapse-admin-tooltip="{{ doc.content|e('html_attr') }}">
                                    {{ doc.content|length > 100 ? doc.content|slice(0, 100) ~ '…' : doc.content }}
                                </div>
                            </td>
                            <td class="synapse-admin-font-mono synapse-admin-text-sm">{{ doc.sourceIdentifier }}</td>
                            <td class="synapse-admin-text-sm">{{ doc.chunkIndex + 1 }} / {{ doc.totalChunks }}</td>
                            <td class="synapse-admin-text-sm">
                                {% if doc.metadata %}
                                    <details class="synapse-admin-collapsible">
                                        <summary class="synapse-admin-text-xs synapse-admin-link" style="cursor: pointer;">
                                            {{ doc.metadata|keys|join(', ') }}
                                        </summary>
                                        <pre class="synapse-admin-font-mono synapse-admin-text-xs" style="margin-top: 0.5rem; white-space: pre-wrap;">{{ doc.metadata|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                                    </details>
                                {% else %}
                                    <span class="synapse-admin-text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="synapse-admin-table__cell--muted">{{ doc.createdAt|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">
                                <div class="synapse-admin-empty">
                                    <div class="synapse-admin-empty__icon"><i data-lucide="file-text"></i></div>
                                    <div class="synapse-admin-empty__title">{{ 'synapse.admin.rag.documents.empty.title'|trans(domain: 'synapse_admin') }}</div>
                                    <p class="synapse-admin-empty__description">{{ 'synapse.admin.rag.documents.empty.subtitle'|trans(domain: 'synapse_admin') }}</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# ── Pagination ────────────────────────────────────────────────────────── #}
        {% if pages > 1 %}
            <div class="synapse-admin-card__footer synapse-admin-justify-between">
                <span class="synapse-admin-text-sm synapse-admin-text-muted">
                    Page {{ page }} / {{ pages }} ({{ total }} chunks)
                </span>
                <div class="synapse-admin-flex synapse-admin-gap-sm">
                    {% if page > 1 %}
                        <a href="{{ path('synapse_admin_rag_sources_documents', {id: source.id, page: page - 1}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                            <i data-lucide="chevron-left"></i>
                        </a>
                    {% endif %}
                    {% if page < pages %}
                        <a href="{{ path('synapse_admin_rag_sources_documents', {id: source.id, page: page + 1}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                            <i data-lucide="chevron-right"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

{% endblock %}
