{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.memory.memories.page_title'|trans(domain='synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.memory'|trans(domain='synapse_admin') }}</a>
	<span class="synapse-admin-topbar__breadcrumb-sep">›</span>
	<span class="synapse-admin-topbar__current">{{ 'synapse.admin.sidebar.memories'|trans(domain='synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

	{# ── En-tête ──────────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-page-header">
		<div class="synapse-admin-page-header__info">
			<h1 class="synapse-admin-page-title">
				<span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="sparkles"></i>
				</span>
				{{ 'synapse.admin.memory.memories.title'|trans(domain='synapse_admin') }}
			</h1>
			<p class="synapse-admin-page-subtitle">
				{{ 'synapse.admin.memory.memories.subtitle'|trans(domain='synapse_admin') }}
			</p>
		</div>
	</div>

	{# ── KPIs ─────────────────────────────────────────────────────────────────── #}
	<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-xl">

		<div class="synapse-admin-card synapse-admin-card--hover">
			<div class="synapse-admin-kpi">
				<div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--primary">
					<i data-lucide="sparkles"></i>
				</div>
				<div class="synapse-admin-kpi__body">
					<div class="synapse-admin-kpi__label">{{ 'synapse.admin.memory.memories.kpi.total_label'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-kpi__value">{{ total }}</div>
					<div class="synapse-admin-kpi__sub">{{ 'synapse.admin.memory.memories.kpi.total_sub'|trans(domain='synapse_admin') }}</div>
				</div>
			</div>
		</div>

		<div class="synapse-admin-card synapse-admin-card--hover">
			<div class="synapse-admin-kpi">
				<div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--info">
					<i data-lucide="file-text"></i>
				</div>
				<div class="synapse-admin-kpi__body">
					<div class="synapse-admin-kpi__label">{{ 'synapse.admin.memory.memories.kpi.this_page_label'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-kpi__value">{{ memories|length }}</div>
					<div class="synapse-admin-kpi__sub">{{ 'synapse.admin.memory.memories.kpi.this_page_sub'|trans({'%limit%': limit}, domain='synapse_admin') }}</div>
				</div>
			</div>
		</div>

		<div class="synapse-admin-card synapse-admin-card--hover">
			<div class="synapse-admin-kpi">
				<div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--neutral">
					<i data-lucide="layers"></i>
				</div>
				<div class="synapse-admin-kpi__body">
					<div class="synapse-admin-kpi__label">{{ 'synapse.admin.memory.memories.kpi.pages_label'|trans(domain='synapse_admin') }}</div>
					<div class="synapse-admin-kpi__value">{{ page }} / {{ pages }}</div>
					<div class="synapse-admin-kpi__sub">{{ 'synapse.admin.memory.memories.kpi.pages_sub'|trans({'%limit%': limit}, domain='synapse_admin') }}</div>
				</div>
			</div>
		</div>

	</div>

	{# ── Tableau des souvenirs ────────────────────────────────────────────────── #}
	<div class="synapse-admin-card">
		<div class="synapse-admin-card__header">
			<div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--primary">
				<i data-lucide="list"></i>
			</div>
			<div>
				<div class="synapse-admin-card__title">{{ 'synapse.admin.memory.memories.list.title'|trans(domain='synapse_admin') }}</div>
				<div class="synapse-admin-card__subtitle">
					{{ 'synapse.admin.memory.memories.list.subtitle'|trans(domain='synapse_admin') }}
				</div>
			</div>
		</div>

		<div class="synapse-admin-table-container">
			<table class="synapse-admin-table">
				<thead>
					<tr>
						<th>{{ 'synapse.admin.memory.memories.table.head.content'|trans(domain='synapse_admin') }}</th>
						<th>{{ 'synapse.admin.memory.memories.table.head.user'|trans(domain='synapse_admin') }}</th>
						<th>{{ 'synapse.admin.memory.memories.table.head.scope'|trans(domain='synapse_admin') }}</th>
						<th>{{ 'synapse.admin.memory.memories.table.head.type'|trans(domain='synapse_admin') }}</th>
						<th>{{ 'synapse.admin.memory.memories.table.head.created_at'|trans(domain='synapse_admin') }}</th>
						<th class="synapse-admin-table__cell--actions">{{ 'synapse.admin.llm_config.model.table.head.actions'|trans(domain='synapse_admin') }}</th>
					</tr>
				</thead>
				<tbody>
					{% for memory in memories %}
						<tr>
							<td>
								<div class="synapse-admin-table-cell-label">
									<div class="synapse-admin-table-cell-label__icon synapse-admin-kpi__icon--primary">
										<i data-lucide="sparkles"></i>
									</div>
									<div>
										<div class="synapse-admin-table-cell-label__title synapse-admin-truncate" data-synapse-admin-tooltip="{{ memory.content|e('html_attr') }}">
											{{ memory.content|length > 80 ? memory.content|slice(0, 80) ~ '…' : memory.content }}
										</div>
										<div class="synapse-admin-table-cell-label__sub synapse-admin-font-mono">#{{ memory.id }}</div>
									</div>
								</div>
							</td>
							<td>
								<div class="synapse-admin-table-cell-label">
									<div class="synapse-admin-table-cell-label__icon synapse-admin-kpi__icon--neutral">
										<i data-lucide="user"></i>
									</div>
									<div>
										<div class="synapse-admin-table-cell-label__title">{{ memory.userId ?? '—' }}</div>
									</div>
								</div>
							</td>
							<td>
								<span class="synapse-admin-badge synapse-admin-badge--neutral">{{ memory.scope }}</span>
							</td>
							<td class="synapse-admin-table__cell--muted">{{ memory.sourceType }}</td>
							<td class="synapse-admin-table__cell--muted">{{ memory.createdAt|date('d/m/Y H:i') }}</td>
							<td class="synapse-admin-table__cell--actions">
								<form action="{{ path('synapse_admin_memories_delete', { id: memory.id }) }}" method="POST" class="synapse-admin-form-inline">
									<input type="hidden" name="token" value="{{ csrf_token('synapse_admin_memories_delete') }}">
									<input type="hidden" name="page" value="{{ page }}">
									<button type="submit" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm synapse-admin-btn--danger synapse-admin-btn--icon"
									        data-synapse-admin-tooltip="{{ 'synapse.admin.memory.memories.action.delete_tooltip'|trans(domain='synapse_admin') }}"
									        onclick="return confirm('{{ 'synapse.admin.memory.memories.action.delete_confirm'|trans(domain='synapse_admin')|escape('js') }}');">
										<i data-lucide="trash-2"></i>
									</button>
								</form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="6">
								<div class="synapse-admin-empty">
									<div class="synapse-admin-empty__icon">
										<i data-lucide="sparkles"></i>
									</div>
									<div class="synapse-admin-empty__title">{{ 'synapse.admin.memory.memories.empty.title'|trans(domain='synapse_admin') }}</div>
									<p class="synapse-admin-empty__description">
										{{ 'synapse.admin.memory.memories.empty.subtitle'|trans(domain='synapse_admin') }}
									</p>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		{# ── Pagination ────────────────────────────────────────────────────────── #}
		{% if pages > 1 %}
			<div class="synapse-admin-card__footer synapse-admin-justify-between">
				<span class="synapse-admin-text-sm synapse-admin-text-muted">
					{{ 'synapse.admin.memory.memories.pagination.summary'|trans({'%page%': page, '%pages%': pages, '%total%': total}, domain='synapse_admin') }}
				</span>
				<div class="synapse-admin-flex synapse-admin-gap-sm">
					{% if page > 1 %}
						<a href="{{ path('synapse_admin_memories', { page: page - 1 }) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
							<i data-lucide="chevron-left"></i>
							{{ 'synapse.admin.memory.memories.pagination.prev'|trans(domain='synapse_admin') }}
						</a>
					{% endif %}
					{% if page < pages %}
						<a href="{{ path('synapse_admin_memories', { page: page + 1 }) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
							{{ 'synapse.admin.memory.memories.pagination.next'|trans(domain='synapse_admin') }}
							<i data-lucide="chevron-right"></i>
						</a>
					{% endif %}
				</div>
			</div>
		{% endif %}

	</div>

{% endblock %}
