{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.debug.page_title'|trans(domain: 'synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <a href="#" class="synapse-admin-topbar__breadcrumb">{{ 'synapse.admin.sidebar.section.system'|trans(domain: 'synapse_admin') }}</a>
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <span class="synapse-admin-topbar__current">{{ 'synapse.admin.sidebar.debug'|trans(domain: 'synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

    {# ── En-tête ──────────────────────────────────────────────────────────────── #}
    <div class="synapse-admin-page-header">
        <div class="synapse-admin-page-header__info">
            <h1 class="synapse-admin-page-title">
                <span class="synapse-admin-page-title__icon synapse-admin-kpi__icon--warning">
                    <i data-lucide="bug"></i>
                </span>
                {{ 'synapse.admin.debug.title'|trans(domain: 'synapse_admin') }}
            </h1>
            <p class="synapse-admin-page-subtitle">
                {{ 'synapse.admin.debug.subtitle'|trans(domain: 'synapse_admin') }}
            </p>
        </div>
        <div class="synapse-admin-page-header__actions">
            <form action="{{ path('synapse_admin_debug_purge') }}" method="POST" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('debug_purge') }}">
                <button type="submit" class="synapse-admin-btn synapse-admin-btn--danger synapse-admin-btn--sm" onclick="return confirm('{{ 'synapse.admin.debug.action.purge_confirm'|trans(domain: 'synapse_admin')|escape('js') }}')">
                    <i data-lucide="flame"></i>
                    {{ 'synapse.admin.debug.action.purge'|trans(domain: 'synapse_admin') }}
                </button>
            </form>
            {% if logs|length > 0 %}
                <form action="{{ path('synapse_admin_debug_clear') }}" method="POST" style="display:inline;">
                    <input type="hidden" name="token" value="{{ csrf_token('debug_clear') }}">
                    <button type="submit" class="synapse-admin-btn synapse-admin-btn--danger synapse-admin-btn--sm" onclick="return confirm('{{ 'synapse.admin.debug.action.clear_confirm'|trans({total: total}, domain: 'synapse_admin')|escape('js') }}')">
                        <i data-lucide="trash-2"></i>
                        {{ 'synapse.admin.debug.action.clear'|trans(domain: 'synapse_admin') }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    {# ── Configuration & KPIs ─────────────────────────────────────────────────── #}
    <div class="synapse-admin-grid synapse-admin-grid--1 synapse-admin-mb-lg">
        <div class="synapse-admin-card" style="background: var(--synapse-admin-bg-subtle);">
            <div class="synapse-admin-card__body synapse-admin-card__body--compact synapse-admin-flex synapse-admin-justify-between synapse-admin-items-center">
                <div class="synapse-admin-flex synapse-admin-items-center synapse-admin-gap-md">
                    <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--{{ config.debugMode ? 'warning' : 'neutral' }}">
                        <i data-lucide="{{ config.debugMode ? 'bug' : 'bug-off' }}"></i>
                    </div>
                    <div>
                        <div class="synapse-admin-card__title">{{ 'synapse.admin.debug.toggle.title'|trans(domain: 'synapse_admin') }}</div>
                        <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.debug.toggle.subtitle'|trans(domain: 'synapse_admin') }}</div>
                    </div>
                </div>
                <form action="{{ path('synapse_admin_debug') }}" method="POST" id="debug-mode-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('synapse_admin_debug_toggle') }}">
                    <input type="hidden" name="debug_mode_toggle" value="1">
                    <label class="synapse-admin-toggle">
                        <input type="checkbox" name="debug_mode" value="1" {{ config.debugMode ? 'checked' : '' }} onchange="this.form.submit()">
                        <span class="synapse-admin-toggle__slider"></span>
                        <span class="synapse-admin-toggle__label">{{ (config.debugMode ? 'synapse.admin.health.status.enabled' : 'synapse.admin.health.status.disabled')|trans(domain: 'synapse_admin') }}</span>
                    </label>
                </form>
            </div>
        </div>
    </div>

    <div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-xl">

        <div class="synapse-admin-card synapse-admin-card--hover">
            <div class="synapse-admin-kpi">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--warning">
                    <i data-lucide="bug"></i>
                </div>
                <div class="synapse-admin-kpi__body">
                    <div class="synapse-admin-kpi__label">{{ 'synapse.admin.debug.kpi.total_label'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-kpi__value">{{ total }}</div>
                    <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.debug.kpi.total_sub'|trans(domain: 'synapse_admin') }}</div>
                </div>
            </div>
        </div>

        <div class="synapse-admin-card synapse-admin-card--hover">
            <div class="synapse-admin-kpi">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--info">
                    <i data-lucide="eye"></i>
                </div>
                <div class="synapse-admin-kpi__body">
                    <div class="synapse-admin-kpi__label">{{ 'synapse.admin.debug.kpi.displayed_label'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-kpi__value">{{ logs|length }}</div>
                    <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.debug.kpi.displayed_sub'|trans(domain: 'synapse_admin') }}</div>
                </div>
            </div>
        </div>

        <div class="synapse-admin-card synapse-admin-card--hover">
            <div class="synapse-admin-kpi">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--{{ config.debugMode ? 'warning' : 'success' }}">
                    <i data-lucide="{{ config.debugMode ? 'activity' : 'check-circle-2' }}"></i>
                </div>
                <div class="synapse-admin-kpi__body">
                    <div class="synapse-admin-kpi__label">{{ 'synapse.admin.debug.kpi.system_label'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-kpi__value">{{ (config.debugMode ? 'synapse.admin.sidebar.section.debug' : 'synapse.admin.debug.kpi.system_optimal')|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-kpi__sub">{{ (config.debugMode ? 'synapse.admin.debug.kpi.system_active' : 'synapse.admin.debug.kpi.system_perf')|trans(domain: 'synapse_admin') }}</div>
                </div>
            </div>
        </div>

    </div>

    {# ── Journal ───────────────────────────────────────────────────────────────── #}
    {% if logs|length == 0 %}
        <div class="synapse-admin-card">
            <div class="synapse-admin-empty">
                <div class="synapse-admin-empty__icon">
                    <i data-lucide="bug-off"></i>
                </div>
                <div class="synapse-admin-empty__title">{{ 'synapse.admin.debug.empty.title'|trans(domain: 'synapse_admin') }}</div>
                <p class="synapse-admin-empty__description">
                    {{ 'synapse.admin.debug.empty.subtitle'|trans(domain: 'synapse_admin')|safe_html }}
                </p>
            </div>
        </div>
    {% else %}

        <div class="synapse-admin-card">
            <div class="synapse-admin-card__header">
                <div class="synapse-admin-card__header-icon synapse-admin-kpi__icon--warning">
                    <i data-lucide="list-ordered"></i>
                </div>
                <div>
                    <div class="synapse-admin-card__title">{{ 'synapse.admin.debug.list.title'|trans(domain: 'synapse_admin') }}</div>
                    <div class="synapse-admin-card__subtitle">{{ 'synapse.admin.debug.list.subtitle'|trans(domain: 'synapse_admin') }}</div>
                </div>
                <div style="margin-left: auto;">
                    <a href="{{ path('synapse_admin_debug', include_children ? {} : {include_children: 1}) }}"
                       class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm">
                        <i data-lucide="{{ include_children ? 'eye-off' : 'eye' }}"></i>
                        {{ (include_children ? 'synapse.admin.debug.filter.hide_children' : 'synapse.admin.debug.filter.show_children')|trans(domain: 'synapse_admin') }}
                    </a>
                </div>
            </div>

            <div class="synapse-admin-table-container">
                <table class="synapse-admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>{{ 'synapse.admin.debug.table.head.module'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.llm_config.tab.models'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.debug.table.head.tokens'|trans(domain: 'synapse_admin') }}</th>
                            <th>{{ 'synapse.admin.memory.memories.table.head.created_at'|trans(domain: 'synapse_admin') }}</th>
                            <th class="synapse-admin-table__cell--actions">{{ 'synapse.admin.debug.table.head.detail'|trans(domain: 'synapse_admin') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td class="synapse-admin-table__cell--mono synapse-admin-text-xs">
                                    {% if log.debugId starts with 'dbg_err_' %}
                                        <span class="synapse-admin-badge synapse-admin-badge--danger" style="margin-right: 4px;">ERR</span>
                                    {% endif %}
                                    {{ log.debugId|slice(0, 12) }}…
                                </td>
                                <td>
                                    {% if log.module %}
                                        <span class="synapse-admin-badge synapse-admin-badge--neutral">{{ ('synapse.admin.analytics.module.' ~ log.module)|synapse_label(log.module) }}</span>
                                        {% if log.action %}
                                            <span class="synapse-admin-badge synapse-admin-badge--info" style="margin-left: 4px;">{{ ('synapse.admin.analytics.action.' ~ log.action)|synapse_label(log.action) }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="synapse-admin-text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="synapse-admin-table__cell--mono synapse-admin-text-xs">
                                    {{ log.model ?? '—' }}
                                </td>
                                <td class="synapse-admin-table__cell--mono">
                                    {{ log.totalTokens ?? '—' }}
                                </td>
                                <td class="synapse-admin-table__cell--muted">
                                    {{ log.createdAt is defined ? log.createdAt|date('d/m H:i:s') : '—' }}
                                </td>
                                <td class="synapse-admin-table__cell--actions">
                                    <a href="{{ path('synapse_debug_show', {id: log.debugId}) }}" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm synapse-admin-btn--icon" target="_blank" data-synapse-admin-tooltip="{{ 'synapse.admin.debug.action.open_report'|trans(domain: 'synapse_admin') }}">
                                        <i data-lucide="external-link"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    {% endif %}

{% endblock %}
