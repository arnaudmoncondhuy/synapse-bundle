{% extends '@Synapse/admin/layout/base.html.twig' %}

{% block admin_page_title %}{{ 'synapse.admin.dashboard.page_title'|trans(domain='synapse_admin') }}{% endblock %}

{% block admin_breadcrumb %}
    <span class="synapse-admin-topbar__breadcrumb-sep">›</span>
    <span class="synapse-admin-topbar__current">{{ 'synapse.admin.dashboard.breadcrumb'|trans(domain='synapse_admin') }}</span>
{% endblock %}

{% block admin_content %}

{# ── Banner onboarding ─────────────────────────────────────────────────────── #}
{% if not system.is_healthy %}
<div class="synapse-admin-onboarding-banner synapse-admin-mb-lg" id="onboarding-banner">
    <div class="synapse-admin-onboarding-banner__content">
        <div class="synapse-admin-onboarding-banner__header">
            <i data-lucide="rocket"></i>
            <span>{{ 'synapse.admin.dashboard.onboarding.title'|trans(domain='synapse_admin') }}</span>
        </div>
        <ol class="synapse-admin-onboarding-banner__steps">
            <li class="synapse-admin-onboarding-banner__step">
                <span class="synapse-admin-onboarding-banner__number">1</span>
                <span>{{ 'synapse.admin.dashboard.onboarding.step1'|trans(domain='synapse_admin') }}</span>
            </li>
            <li class="synapse-admin-onboarding-banner__step">
                <span class="synapse-admin-onboarding-banner__number">2</span>
                <span>{{ 'synapse.admin.dashboard.onboarding.step2'|trans(domain='synapse_admin') }}</span>
            </li>
            <li class="synapse-admin-onboarding-banner__step">
                <span class="synapse-admin-onboarding-banner__number">3</span>
                <span>{{ 'synapse.admin.dashboard.onboarding.step3'|trans(domain='synapse_admin') }}</span>
            </li>
        </ol>
    </div>
    <div class="synapse-admin-onboarding-banner__actions">
        <a href="{{ path('synapse_admin_configuration_llm') }}" class="synapse-admin-btn synapse-admin-btn--primary synapse-admin-btn--sm">
            <i data-lucide="plus"></i>
            {{ 'synapse.admin.dashboard.onboarding.action'|trans(domain='synapse_admin') }}
        </a>
        <button type="button" class="synapse-admin-btn synapse-admin-btn--ghost synapse-admin-btn--sm" onclick="document.getElementById('onboarding-banner').remove();">
            <i data-lucide="x"></i>
        </button>
    </div>
</div>
{% endif %}

{# ── Bandeau déprécation modèles (J-30) ───────────────────────────────────── #}
{% if deprecation_warnings is defined and deprecation_warnings is not empty %}
<div class="synapse-admin-card synapse-admin-card--{% if deprecation_warnings|filter(w => w.expired)|length > 0 %}danger{% else %}warning{% endif %} synapse-admin-mb-lg">
    <div class="synapse-admin-card__body">
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
            <i data-lucide="alert-triangle" style="flex-shrink:0;margin-top:0.15rem;"></i>
            <div style="flex:1;">
                <div style="font-weight:600;margin-bottom:0.5rem;">
                    {{ 'synapse.admin.dashboard.deprecation.title'|trans(domain='synapse_admin') }}
                </div>
                <ul style="margin:0;padding-left:1.25rem;font-size:0.9rem;line-height:1.6;">
                    {% for w in deprecation_warnings %}
                        <li>
                            <strong>{{ w.preset_name }}</strong>
                            <span style="color:var(--synapse-admin-text-secondary);">— {{ w.provider }} / {{ w.model }}</span>
                            {% if w.expired %}
                                · <span style="color:var(--synapse-admin-danger);font-weight:500;">
                                    {{ 'synapse.admin.dashboard.deprecation.expired'|trans({'date': w.deprecated_at}, 'synapse_admin') }}
                                </span>
                            {% else %}
                                · <span style="color:var(--synapse-admin-warning);font-weight:500;">
                                    {{ 'synapse.admin.dashboard.deprecation.upcoming'|trans({'date': w.deprecated_at, 'days': w.days_left}, 'synapse_admin') }}
                                </span>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <div style="margin-top:0.75rem;">
                    <a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" class="synapse-admin-btn synapse-admin-btn--sm synapse-admin-btn--outline">
                        <i data-lucide="arrow-right"></i>
                        {{ 'synapse.admin.dashboard.deprecation.action'|trans(domain='synapse_admin') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# ── En-tête ──────────────────────────────────────────────────────────────── #}
<div class="synapse-admin-page-header synapse-admin-mb-xl">
    <div class="synapse-admin-page-header__info">
        <h1 class="synapse-admin-page-title">{{ 'synapse.admin.dashboard.title'|trans(domain='synapse_admin') }}</h1>
        <p class="synapse-admin-page-subtitle">{{ 'synapse.admin.dashboard.subtitle'|trans(domain='synapse_admin') }}</p>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# BLOC 1 — ÉTAT DU SYSTÈME                                                  #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<h2 class="synapse-admin-section-title synapse-admin-mb-md">
    <i data-lucide="activity"></i>
    {{ 'synapse.admin.dashboard.section.system'|trans(domain='synapse_admin') }}
</h2>
<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-xl">

    {# Preset actif #}
    {% set preset_ok = system.preset is not null and system.providers_active > 0 %}
    <div class="synapse-admin-card synapse-admin-card--hover {% if not preset_ok %}synapse-admin-card--warning{% endif %}">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon {% if preset_ok %}synapse-admin-kpi__icon--primary{% else %}synapse-admin-kpi__icon--warning{% endif %}">
                <i data-lucide="sliders-horizontal"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.system.preset'|trans(domain='synapse_admin') }}</div>
                {% if preset_ok %}
                    <div class="synapse-admin-kpi__value" style="font-size:1.05rem;">{{ system.preset.name }}</div>
                    <div class="synapse-admin-kpi__sub">{{ system.preset.providerName }} · {{ system.preset.model }}</div>
                {% else %}
                    <div class="synapse-admin-kpi__value" style="font-size:0.95rem;color:var(--synapse-admin-warning);">
                        {{ 'synapse.admin.dashboard.kpi.incomplete'|trans(domain='synapse_admin') }}
                    </div>
                    <div class="synapse-admin-kpi__sub">
                        {% if system.preset is null %}
                            <a href="{{ path('synapse_admin_configuration_llm', {tab: 'presets'}) }}" style="color:var(--synapse-admin-warning);font-weight:500;">
                                {{ 'synapse.admin.dashboard.kpi.create_preset'|trans(domain='synapse_admin') }}
                            </a>
                        {% else %}
                            <a href="{{ path('synapse_admin_configuration_llm', {tab: 'fournisseurs'}) }}" style="color:var(--synapse-admin-warning);font-weight:500;">
                                {{ 'synapse.admin.dashboard.kpi.config_provider'|trans(domain='synapse_admin') }}
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Providers #}
    {% set providers_ok = system.providers_active > 0 %}
    <div class="synapse-admin-card synapse-admin-card--hover">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon {% if providers_ok %}synapse-admin-kpi__icon--success{% else %}synapse-admin-kpi__icon--warning{% endif %}">
                <i data-lucide="plug"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.system.providers'|trans(domain='synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">{{ system.providers_active }} <span style="font-size:0.9rem;font-weight:400;color:var(--synapse-admin-text-secondary);">/ {{ system.providers_total }}</span></div>
                <div class="synapse-admin-kpi__sub">
                    {% if system.providers_list is not empty %}
                        {{ system.providers_list|map(p => p.label)|join(', ') }}
                    {% else %}
                        <a href="{{ path('synapse_admin_configuration_llm') }}" style="color:var(--synapse-admin-warning);font-weight:500;">
                            {{ 'synapse.admin.dashboard.kpi.config_provider'|trans(domain='synapse_admin') }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# Alertes budget #}
    {% set has_alerts = system.alerts_count > 0 %}
    <a href="{{ path('synapse_admin_spending_alerts') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon {% if has_alerts %}synapse-admin-kpi__icon--danger{% else %}synapse-admin-kpi__icon--success{% endif %}">
                <i data-lucide="bell{% if has_alerts %}-ring{% endif %}"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.system.alerts'|trans(domain='synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">{{ system.alerts_count }}</div>
                <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.dashboard.system.alerts_sub'|trans(domain='synapse_admin') }}</div>
            </div>
        </div>
    </a>

</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# BLOC 2 — ACTIVITÉ 7 JOURS                                                 #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<h2 class="synapse-admin-section-title synapse-admin-mb-md">
    <i data-lucide="bar-chart-3"></i>
    {{ 'synapse.admin.dashboard.section.activity'|trans(domain='synapse_admin') }}
    <span class="synapse-admin-section-title__hint">{{ 'synapse.admin.dashboard.section.activity_hint'|trans(domain='synapse_admin') }}</span>
    <a href="{{ path('synapse_admin_analytics') }}" class="synapse-admin-section-title__link">
        {{ 'synapse.admin.common.see_all'|trans(domain='synapse_admin') }} <i data-lucide="arrow-right"></i>
    </a>
</h2>
<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-xl">

    {# Tokens consommés #}
    <div class="synapse-admin-card synapse-admin-card--hover">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--primary">
                <i data-lucide="zap"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.kpi.tokens_7d'|trans(domain='synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">{{ (activity.tokens ?? 0)|number_format(0, ',', ' ') }}</div>
                <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.dashboard.activity.tokens_sub'|trans(domain='synapse_admin') }}</div>
            </div>
        </div>
    </div>

    {# Requêtes LLM #}
    <div class="synapse-admin-card synapse-admin-card--hover">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--indigo">
                <i data-lucide="messages-square"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.activity.requests'|trans(domain='synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">{{ (activity.requests ?? 0)|number_format(0, ',', ' ') }}</div>
                <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.dashboard.activity.requests_sub'|trans(domain='synapse_admin') }}</div>
            </div>
        </div>
    </div>

    {# Coût estimé 7j #}
    <a href="{{ path('synapse_admin_analytics') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-kpi">
            <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--success">
                <i data-lucide="coins"></i>
            </div>
            <div class="synapse-admin-kpi__body">
                <div class="synapse-admin-kpi__label">{{ 'synapse.admin.dashboard.activity.cost'|trans(domain='synapse_admin') }}</div>
                <div class="synapse-admin-kpi__value">
                    {% if (activity.costs_eur ?? 0) > 0 %}
                        {{ activity.costs_eur|number_format(4) }} €
                    {% elseif (activity.costs_usd ?? 0) > 0 %}
                        {{ activity.costs_usd|number_format(4) }} $
                    {% else %}
                        0.00
                    {% endif %}
                </div>
                <div class="synapse-admin-kpi__sub">{{ 'synapse.admin.dashboard.activity.cost_sub'|trans(domain='synapse_admin') }}</div>
            </div>
        </div>
    </a>

</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# BLOC 3 — INVENTAIRE + RACCOURCIS                                          #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<h2 class="synapse-admin-section-title synapse-admin-mb-md">
    <i data-lucide="layout-grid"></i>
    {{ 'synapse.admin.dashboard.section.shortcuts'|trans(domain='synapse_admin') }}
</h2>
<div class="synapse-admin-grid synapse-admin-grid--3 synapse-admin-mb-xl">

    {# Intelligence / Config LLM #}
    <a href="{{ path('synapse_admin_configuration_llm') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--primary synapse-admin-shortcut__icon">
                    <i data-lucide="sliders-horizontal"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.presets.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">{{ inventory.presets_total }} {{ 'synapse.admin.dashboard.shortcut.presets.count'|trans(domain='synapse_admin') }}</div>
                </div>
            </div>
        </div>
    </a>

    {# Agents #}
    <a href="{{ path('synapse_admin_agents') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--indigo synapse-admin-shortcut__icon">
                    <i data-lucide="bot"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.agents.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">
                        {{ inventory.agents_total }} {{ 'synapse.admin.dashboard.shortcut.agents.count'|trans(domain='synapse_admin') }}
                        {% if inventory.agents_custom > 0 %}
                            · {{ inventory.agents_custom }} {{ 'synapse.admin.dashboard.shortcut.agents.custom'|trans(domain='synapse_admin') }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </a>

    {# Outils #}
    <a href="{{ path('synapse_admin_tools') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-kpi__icon--success synapse-admin-shortcut__icon">
                    <i data-lucide="wrench"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.tools.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">{{ inventory.tools_total }} {{ 'synapse.admin.dashboard.shortcut.tools.count'|trans(domain='synapse_admin') }}</div>
                </div>
            </div>
        </div>
    </a>

    {# Personnalité #}
    <a href="{{ path('synapse_admin_tones') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-shortcut__icon" style="background:hsl(280,70%,95%);color:hsl(280,70%,45%);">
                    <i data-lucide="smile"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.personality.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">{{ 'synapse.admin.dashboard.shortcut.personality.desc'|trans(domain='synapse_admin') }}</div>
                </div>
            </div>
        </div>
    </a>

    {# Embeddings & RAG #}
    <a href="{{ path('synapse_admin_embeddings') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-shortcut__icon" style="background:hsl(170,70%,93%);color:hsl(170,60%,35%);">
                    <i data-lucide="database-zap"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.rag.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">{{ inventory.memories_total }} {{ 'synapse.admin.dashboard.shortcut.rag.count'|trans(domain='synapse_admin') }}</div>
                </div>
            </div>
        </div>
    </a>

    {# Analytics #}
    <a href="{{ path('synapse_admin_analytics') }}" class="synapse-admin-card synapse-admin-card--hover" style="text-decoration:none;">
        <div class="synapse-admin-card__body synapse-admin-card__body--compact">
            <div class="synapse-admin-shortcut">
                <div class="synapse-admin-kpi__icon synapse-admin-shortcut__icon" style="background:hsl(38,90%,95%);color:hsl(38,80%,40%);">
                    <i data-lucide="bar-chart-3"></i>
                </div>
                <div>
                    <div class="synapse-admin-shortcut__title">{{ 'synapse.admin.dashboard.shortcut.analytics.title'|trans(domain='synapse_admin') }}</div>
                    <div class="synapse-admin-shortcut__meta">{{ 'synapse.admin.dashboard.shortcut.analytics.desc'|trans(domain='synapse_admin') }}</div>
                </div>
            </div>
        </div>
    </a>

</div>

{% endblock %}
