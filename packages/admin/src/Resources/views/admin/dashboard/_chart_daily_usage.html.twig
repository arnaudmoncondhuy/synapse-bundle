{# Macro réutilisable pour graphique quotidien — utilisée sur dashboard et analytics #}
{% macro render(daily_usage, period) %}
    {% if daily_usage is empty %}
        <div class="synapse-admin-text-secondary synapse-admin-text-center" style="padding: 40px 0;">Aucune donnée disponible pour cette période.</div>
    {% else %}
        {% set max_tokens = 1 %}
        {% for day in daily_usage %}
            {% if (day.total_tokens ?? 0) > max_tokens %}{% set max_tokens = day.total_tokens %}{% endif %}
        {% endfor %}

        {# Zone graphique avec grille #}
        <div style="position: relative; height: 140px; margin-bottom: 4px;">

            {# Ligne de base (0) #}
            <div style="position: absolute; bottom: 0; left: 0; right: 0; border-top: 1px solid var(--synapse-admin-border); pointer-events: none;"></div>

            {# Lignes de grille horizontales (25 / 50 / 75 / 100 %) #}
            {% for pct in [100, 75, 50, 25] %}
                <div style="position: absolute; left: 0; right: 0; bottom: {{ pct }}%; border-top: 1px dashed var(--synapse-admin-border); pointer-events: none;"></div>
            {% endfor %}

            {# Barres #}
            <div style="position: absolute; inset: 0; display: flex; align-items: flex-end; gap: 3px;">
                {% for day in daily_usage %}
                    <div
                        data-synapse-admin-tooltip="{{ day.date }} · {{ (day.total_tokens ?? 0)|number_format(0, '', ' ') }} tokens"
                        style="flex: 1; height: {{ max_tokens > 0 ? ((day.total_tokens ?? 0) / max_tokens * 100)|round : 0 }}%; min-width: 4px; border-radius: 2px 2px 0 0; background: var(--synapse-admin-primary); opacity: {{ (day.total_tokens ?? 0) > 0 ? '0.85' : '0.12' }}; transition: opacity .15s;"
                    ></div>
                {% endfor %}
            </div>
        </div>

        <div class="synapse-admin-flex synapse-admin-justify-between synapse-admin-text-xs synapse-admin-text-secondary synapse-admin-mt-sm">
            <span>Il y a {{ period }} jours</span>
            <span>Aujourd'hui</span>
        </div>
    {% endif %}
{% endmacro %}
