{#
  Partial partagé pour l'affichage d'une pièce jointe (image, PDF, texte, audio, vidéo).
  Utilisé dans le tchat (historique SSR) et la page de debug admin.

  Paramètres :
    - mime_type  (string)           : type MIME du fichier (ex: 'image/png', 'application/pdf')
    - url        (string)           : URL de la ressource (route servie ou data URI)
    - name       (string|null)      : nom d'affichage (nom original ou label dérivé du MIME)
    - mode       (string, 'serve')  : 'serve' = route servie (lien cliquable), 'inline' = data URI (debug, pas de lien)
#}
{% set mode = mode|default('serve') %}
{% set name = name|default(null) %}

{% if mime_type starts with 'image/' %}
    {# ── Image : miniature ── #}
    <img src="{{ url }}" alt="{{ name ?? 'Image' }}" style="max-width: 300px; border-radius: 8px; border: 1px solid #bae6fd;" loading="lazy">

{% elseif mime_type == 'application/pdf' %}
    {# ── PDF ── #}
    {% set badge_style = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; font-size: 0.85rem; color: #92400e; text-decoration: none;' %}
    {% set icon %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
    {% endset %}
    {% if mode == 'serve' %}
        <a href="{{ url }}" style="{{ badge_style }}" target="_blank" rel="noopener">{{ icon }} {{ name ?? 'PDF' }}</a>
    {% else %}
        <span style="{{ badge_style }}">{{ icon }} {{ name ?? 'PDF' }}</span>
    {% endif %}

{% elseif mime_type starts with 'text/' %}
    {# ── Fichier texte ── #}
    {% set badge_style = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #e0f2fe; border: 1px solid #38bdf8; border-radius: 6px; font-size: 0.85rem; color: #0c4a6e; text-decoration: none;' %}
    {% set icon %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
    {% endset %}
    {% if mode == 'serve' %}
        <a href="{{ url }}" style="{{ badge_style }}" target="_blank" rel="noopener">{{ icon }} {{ name ?? 'Texte' }}</a>
    {% else %}
        <span style="{{ badge_style }}">{{ icon }} {{ name ?? 'Texte' }}</span>
    {% endif %}

{% elseif mime_type starts with 'audio/' %}
    {# ── Audio ── #}
    {% set badge_style = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #f3e8ff; border: 1px solid #a78bfa; border-radius: 6px; font-size: 0.85rem; color: #5b21b6; text-decoration: none;' %}
    {% set icon %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
    {% endset %}
    {% if mode == 'serve' %}
        <a href="{{ url }}" style="{{ badge_style }}" target="_blank" rel="noopener">{{ icon }} {{ name ?? 'Audio' }}</a>
    {% else %}
        <span style="{{ badge_style }}">{{ icon }} {{ name ?? 'Audio' }}</span>
    {% endif %}

{% elseif mime_type starts with 'video/' %}
    {# ── Vidéo ── #}
    {% set badge_style = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #fce7f3; border: 1px solid #f472b6; border-radius: 6px; font-size: 0.85rem; color: #9d174d; text-decoration: none;' %}
    {% set icon %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
    {% endset %}
    {% if mode == 'serve' %}
        <a href="{{ url }}" style="{{ badge_style }}" target="_blank" rel="noopener">{{ icon }} {{ name ?? 'Vidéo' }}</a>
    {% else %}
        <span style="{{ badge_style }}">{{ icon }} {{ name ?? 'Vidéo' }}</span>
    {% endif %}

{% else %}
    {# ── Type inconnu (fallback) ── #}
    {% set badge_style = 'display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: #f1f5f9; border: 1px solid #94a3b8; border-radius: 6px; font-size: 0.85rem; color: #475569; text-decoration: none;' %}
    {% set icon %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    {% endset %}
    {% if mode == 'serve' %}
        <a href="{{ url }}" style="{{ badge_style }}" target="_blank" rel="noopener">{{ icon }} {{ name ?? mime_type }}</a>
    {% else %}
        <span style="{{ badge_style }}">{{ icon }} {{ name ?? mime_type }}</span>
    {% endif %}
{% endif %}
